---
import '../styles/globals.css';

interface Props {
  title?: string;
}
const { title = "Portfolio // Fidelity System" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Open source projects, portfolio & creative notes with the Fidelity design system." />

  <!-- Design System Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
</head>
<body class="antialiased min-h-full">
  <slot />
</body>
</html>