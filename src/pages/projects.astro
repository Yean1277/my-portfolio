---
/**
 * src/pages/projects.astro
 *
 * Pattern A — "Project + Process" page for a portfolio with one real project.
 *
 * Layout:
 *  1. Page header — label + bold statement + subhead
 *  2. Featured project card — split card (preview + meta + tech + CTAs)
 *  3. Build log — vertical timeline of milestones
 *  4. Written along the way — 2-col grid of related blog posts
 *  5. Roadmap — Now / Next / Later, three columns
 *  6. Bottom CTA — collaborate / contact
 *
 * Styling inherits from DESIGN.md tokens (teal #39c5bb, warm ink, soft shadows,
 * 1100px max-width, Inter + JetBrains Mono). No new tokens introduced.
 */

import BaseLayout      from '../layouts/BaseLayout.astro';
import Navigation      from '../components/Navigation.astro';
import SiteFooter      from '../components/SiteFooter.astro';
import MusicPlayer     from '../components/MusicPlayer.astro';

// ── The one real project ─────────────────────────────────────────────────────
// Edit these strings — they're the only thing that needs to be true.
const featured = {
  title:       'Yean Ter Portfolio',
  oneLiner:    'A personal portfolio built with Astro, Tailwind, and a healthy obsession with detail.',
  description: 'The site you\'re reading right now. Built from scratch as both a portfolio and a sandbox — every component (the floating music player, the cinematic hero, the per-category card system) was a chance to learn something new about Astro islands, design tokens, or motion.',
  liveHref:    'https://your-portfolio.example',
  repoHref:    'https://github.com/yourname/portfolio',
  meta: [
    { label: 'Started',    value: 'Mar 2026' },
    { label: 'Components', value: '9' },
    { label: 'Stack',      value: 'Astro · TS' },
  ],
};

// ── Build log — milestones ──────────────────────────────────────────────────
// One line per entry. Dates honest. Most recent at the top.
const buildLog = [
  { date: 'May  4, 2026', title: 'Floating music player',     summary: 'Promoted the sidebar player to a viewport-anchored island. Spinning vinyl follows you down the page.' },
  { date: 'May  3, 2026', title: 'Cinematic hero redesign',   summary: 'Replaced the inline hero card with a full-bleed slideshow + centered CTAs. Set the mood up front.' },
  { date: 'Apr 28, 2026', title: 'Per-category color system', summary: 'RecentPosts cards earn a left accent bar, tinted code badge, and a dedicated palette per category.' },
  { date: 'Apr 17, 2026', title: 'Music player MVP',          summary: 'Built audio engine, playlist drawer, vinyl spin animation. Plain SVG, zero framework JS.' },
  { date: 'Apr 10, 2026', title: 'Tokens + DESIGN.md',        summary: 'Locked colour, type, spacing, and shadow into a single document. Stops design drift.' },
  { date: 'Mar 22, 2026', title: 'First Astro prototype',     summary: 'Migrated from a Next.js sketch. Rebuilt the home page on islands. Half the JS, twice the speed.' },
];

// ── Written along the way ───────────────────────────────────────────────────
// Pull from real posts when collection exists; demo data otherwise.
// These are the posts that match the build, not random links.
const writeups = [
  {
    title:    'Building a Music Player in Astro',
    excerpt:  'No framework JS — just Astro islands and a spinning vinyl record made from plain SVG.',
    href:     '/posts/music-player-astro',
    date:     'Apr 17, 2026',
    category: 'Dev',
    tags:     ['Astro', 'Audio'],
  },
  {
    title:    'Designing Card-Based UI Systems',
    excerpt:  'Per-category color tokens, hover micro-interactions, and the geometry of a 78px code square.',
    href:     '/posts/card-based-ui-systems',
    date:     'Apr 24, 2026',
    category: 'Design',
    tags:     ['UI', 'Astro'],
  },
  {
    title:    'Three.js Particle Systems on a Budget',
    excerpt:  '60fps star-field effects without a beefy GPU — instanced mesh and frustum culling.',
    href:     '/posts/threejs-particle-budget',
    date:     'Apr  3, 2026',
    category: 'Dev',
    tags:     ['Three.js', 'WebGL'],
  },
  {
    title:    'Why I Switched from Next.js to Astro',
    excerpt:  'Hydration budget, island architecture, and the joy of zero JS by default.',
    href:     '/posts/nextjs-to-astro',
    date:     'Mar 20, 2026',
    category: 'Dev',
    tags:     ['Astro', 'Next.js'],
  },
];

// Category accent colours for writeup card left bars
const catAccent: Record<string, string> = {
  Anime:   '#F07535',
  Design:  '#39c5bb',
  Dev:     '#5c5a55',
  Journal: '#F5B3C8',
};

// ── Roadmap — Now / Next / Later ────────────────────────────────────────────
// Keep each line short and honest. No filler.
const roadmap = {
  now: [
    'Polishing the projects page (this one)',
    'Wiring up real content collections for posts',
    'Writing the music-player teardown post',
  ],
  next: [
    'Anime tracker page with seasonal grid',
    'Three.js star-field for /about hero',
    'Tag filter + search on the posts index',
  ],
  later: [
    'RSS feed and sitemap automation',
    'Dark mode (proper, not just inverted)',
    'Possibly a CMS for posts I write on the train',
  ],
};

---

<BaseLayout title="Projects — Yean Ter">
  <Navigation />

  <!-- Soft ambient teal glow that follows the user down the page -->
  <div
    class="fixed left-1/3 w-[500px] h-[500px] rounded-full blur-3xl pointer-events-none -z-10"
    style="top:30vh;background:rgba(57,197,187,0.04);"
    aria-hidden="true"
  ></div>

  <main
    class="max-w-[1100px] mx-auto px-6 pt-24 pb-20"
  >

    <!-- 1 ── PAGE HEADER ────────────────────────────────────────────────── -->
    <header class="mb-14">
      <!-- Tiny breadcrumb-style label -->
      <div class="flex items-center gap-2 mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#39c5bb] animate-pulse" aria-hidden="true"></span>
        <span class="text-[10px] font-black tracking-[0.22em] uppercase text-[#39c5bb]">
          Workspace · Projects
        </span>
      </div>

      <!-- Big honest line -->
      <h1
        class="font-medium tracking-tight leading-[1.05] mb-4"
        style="font-size: clamp(2.2rem, 5vw, 3.4rem); color:#24231f;"
      >
        What I'm building,<br/>
        <span class="text-[#39c5bb]">in detail.</span>
      </h1>

      <!-- Subhead -->
      <p class="text-[15px] max-w-xl leading-relaxed" style="color:#787670;">
        One project at a time, with intent. Right now there's just one — but each piece of it is
        documented, written about, and (usually) shipped before I move on.
      </p>
    </header>

    <!-- 2 ── FEATURED PROJECT CARD ──────────────────────────────────────── -->
    <section aria-labelledby="featured-heading" class="mb-20">

      <!-- Section label -->
      <div class="flex items-center gap-2 mb-5">
        <span class="text-[10px] font-medium tracking-[0.18em] uppercase" style="color:#a8a69f;">
          Featured Project · 01
        </span>
        <div class="flex-1 h-px bg-[#ece9e0]"></div>
      </div>

      <!-- The project card -->
      <article
        class="relative bg-white rounded-3xl border border-[#ece9e0] overflow-hidden shadow-[0_8px_40px_rgba(36,35,31,0.04)] hover:shadow-[0_12px_48px_rgba(57,197,187,0.10)] transition-shadow duration-500"
      >
        <!-- Meta + CTA -->
        <div class="p-7 lg:p-9 flex flex-col">

          <!-- Title -->
          <h2
            id="featured-heading"
            class="font-medium leading-tight tracking-tight mb-2"
            style="font-size: clamp(1.5rem, 2.4vw, 1.85rem); color:#24231f;"
          >
            {featured.title}
          </h2>

          <!-- One-liner -->
          <p class="text-[13px] mb-4 leading-snug" style="color:#787670;">
            {featured.oneLiner}
          </p>

          <!-- Description -->
          <p class="text-[13px] leading-relaxed mb-6" style="color:#3a3833;">
            {featured.description}
          </p>

          <!-- Meta strip — small honest numbers -->
          <div class="grid grid-cols-3 gap-3 mb-6 pt-5 border-t border-[#ece9e0]">
            {featured.meta.map(m => (
              <div>
                <p class="text-[9px] font-medium uppercase tracking-[0.15em] mb-1" style="color:#787670;">
                  {m.label}
                </p>
                <p class="text-[12px] font-mono" style="color:#3a3833;">{m.value}</p>
              </div>
            ))}
          </div>

          <!-- CTAs — pushed to bottom of card -->
          <div class="flex items-center gap-3 mt-auto flex-wrap">
            <a
              href={featured.liveHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 bg-[#39c5bb] hover:bg-[#2ba8a0] text-white font-medium text-[13px] px-5 py-2.5 rounded-full shadow-[0_4px_20px_rgba(57,197,187,0.25)] hover:shadow-[0_6px_24px_rgba(57,197,187,0.4)] hover:-translate-y-0.5 transition-all duration-150 ease-site"
            >
              View Live
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href={featured.repoHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 bg-[#24231f] hover:bg-[#3a3833] text-white font-medium text-[13px] px-5 py-2.5 rounded-full hover:-translate-y-0.5 transition-all duration-200"
            >
              <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              View Source
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M3 3H9V9M3 9L9 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </article>
    </section>

    <!-- 3 ── BUILD LOG ──────────────────────────────────────────────────── -->
    <section aria-labelledby="build-log-heading" class="mb-20">

      <!-- Section label -->
      <div class="flex items-center gap-2 mb-7">
        <span id="build-log-heading" class="text-[10px] font-medium tracking-[0.18em] uppercase" style="color:#a8a69f;">
          Build Log · Most Recent First
        </span>
        <div class="flex-1 h-px bg-[#ece9e0]"></div>
      </div>

      <!-- Vertical timeline -->
      <ol class="relative space-y-5 pl-8 before:absolute before:left-2 before:top-2 before:bottom-2 before:w-px before:bg-[#ece9e0]">
        {buildLog.map((entry, i) => (
          <li class="relative">
            <!-- Timeline dot -->
            <span
              class:list={[
                'absolute -left-[26px] top-1 w-3 h-3 rounded-full border-2 border-white',
                i === 0 ? 'bg-[#39c5bb] shadow-[0_0_0_3px_rgba(57,197,187,0.18)]' : 'bg-[#a8a69f]',
              ]}
              aria-hidden="true"
            ></span>

            <!-- Entry -->
            <div class="bg-white rounded-2xl border border-[#ece9e0] px-5 py-4 hover:border-[#39c5bb]/30 hover:shadow-[0_4px_20px_rgba(57,197,187,0.06)] transition-all duration-200">
              <div class="flex items-baseline gap-3 mb-1 flex-wrap">
                <h3 class="text-[14px] font-medium tracking-tight" style="color:#24231f;">{entry.title}</h3>
                <span class="text-[10px] font-mono tabular-nums ml-auto" style="color:#a8a69f;">{entry.date}</span>
              </div>
              <p class="text-[12px] leading-relaxed" style="color:#787670;">{entry.summary}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- 4 ── WRITTEN ALONG THE WAY ──────────────────────────────────────── -->
    <section aria-labelledby="writeups-heading" class="mb-20">

      <!-- Section label -->
      <div class="flex items-center justify-between mb-7 gap-4">
        <div class="flex items-center gap-2">
          <span id="writeups-heading" class="text-[10px] font-medium tracking-[0.18em] uppercase" style="color:#a8a69f;">
            Written Along the Way
          </span>
        </div>
        <div class="flex-1 h-px bg-[#ece9e0]"></div>
        <a
          href="/posts"
          class="text-[11px] font-medium hover:text-[#39c5bb] transition-colors flex items-center gap-1 shrink-0"
          style="color:#787670;"
        >
          All posts
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 5H8M5 2L8 5L5 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- 2-col grid of writeup cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {writeups.map(post => {
          const accent = catAccent[post.category] ?? catAccent.Dev;
          return (
            <a
              href={post.href}
              class="group flex items-stretch bg-white rounded-2xl border border-[#ece9e0] overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_6px_24px_rgba(36,35,31,0.06)]"
            >
              <!-- Left accent bar -->
              <div
                class="w-[4px] shrink-0 transition-all duration-300 group-hover:w-1.5"
                style={`background:${accent};`}
              ></div>

              <div class="flex-1 px-5 py-4 min-w-0">

                <!-- Date -->
                <p class="text-[10px] italic mb-1.5" style="color:#787670;">{post.date}</p>

                <!-- Title -->
                <h3
                  class="text-[14px] font-medium leading-snug tracking-tight line-clamp-1 transition-colors duration-200 group-hover:text-[#39c5bb]"
                  style="color:#24231f;"
                >
                  {post.title}
                </h3>

                <!-- Excerpt -->
                <p class="text-[12px] leading-relaxed mt-1 line-clamp-2" style="color:#787670;">
                  {post.excerpt}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- 5 ── ROADMAP ────────────────────────────────────────────────────── -->
    <section aria-labelledby="roadmap-heading" class="mb-20">

      <!-- Section label -->
      <div class="flex items-center gap-2 mb-7">
        <span id="roadmap-heading" class="text-[10px] font-medium tracking-[0.18em] uppercase" style="color:#a8a69f;">
          Roadmap · Now / Next / Later
        </span>
        <div class="flex-1 h-px bg-[#ece9e0]"></div>
      </div>

      <!-- Three columns -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <!-- NOW — teal accent -->
        <div class="bg-white rounded-2xl border border-[#ece9e0] p-6 hover:border-[#39c5bb]/30 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[#39c5bb] animate-pulse"></span>
            <span class="text-[10px] font-medium tracking-[0.2em] uppercase text-[#39c5bb]">Now</span>
          </div>
          <ul class="space-y-2.5">
            {roadmap.now.map(item => (
              <li class="flex items-start gap-2.5 text-[13px] leading-snug" style="color:#3a3833;">
                <span class="text-[#39c5bb] mt-1 shrink-0">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- NEXT — yuru orange -->
        <div class="bg-white rounded-2xl border border-[#ece9e0] p-6 hover:border-yuru/30 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-yuru"></span>
            <span class="text-[10px] font-medium tracking-[0.2em] uppercase text-yuru">Next</span>
          </div>
          <ul class="space-y-2.5">
            {roadmap.next.map(item => (
              <li class="flex items-start gap-2.5 text-[13px] leading-snug" style="color:#3a3833;">
                <span class="text-yuru mt-1 shrink-0">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- LATER — warm muted -->
        <div class="bg-white rounded-2xl border border-[#ece9e0] p-6 hover:border-[#ece9e0] transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[#a8a69f]"></span>
            <span class="text-[10px] font-medium tracking-[0.2em] uppercase" style="color:#787670;">Later</span>
          </div>
          <ul class="space-y-2.5">
            {roadmap.later.map(item => (
              <li class="flex items-start gap-2.5 text-[13px] leading-snug" style="color:#787670;">
                <span class="mt-1 shrink-0" style="color:#a8a69f;">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- 6 ── BOTTOM CTA ─────────────────────────────────────────────────── -->
    <section
      class="relative bg-white rounded-3xl border border-[#ece9e0] px-8 py-12 text-center overflow-hidden"
      aria-labelledby="cta-heading"
    >
      <!-- Subtle teal glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background:radial-gradient(circle at 50% 100%, rgba(57,197,187,0.08), transparent 60%);"
        aria-hidden="true"
      ></div>

      <div class="relative">
        <h3
          id="cta-heading"
          class="font-medium tracking-tight mb-3"
          style="font-size: clamp(1.4rem, 2.4vw, 1.75rem); color:#24231f;"
        >
          Want to collaborate, or just chat?
        </h3>
        <p class="text-[14px] mb-6 max-w-md mx-auto leading-relaxed" style="color:#787670;">
          I'm open to interesting projects, feedback on the build, or recommendations for what to read next.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 bg-[#39c5bb] hover:bg-[#2ba8a0] text-white font-bold text-[13px] px-7 py-3 rounded-full shadow-[0_4px_24px_rgba(57,197,187,0.25)] hover:shadow-[0_6px_28px_rgba(57,197,187,0.4)] hover:-translate-y-0.5 transition-all duration-150 ease-site"
        >
          Get in touch
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <SiteFooter ownerName="Yean Ter" />
  <MusicPlayer />
</BaseLayout>