---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pages = await getCollection('pages');
const projectsPage = pages.find(p => p.slug === 'projects');

if (!projectsPage) throw new Error('Projects page not found');
const { Content } = await projectsPage.render();
---
<BaseLayout title="Projects | Personal Workspace">
  <main class="container mx-auto px-4 mt-32 mb-24">
    <Content />
  </main>
</BaseLayout>
