---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
 
const pageData = await getCollection('pageData');
const projectsPage = pageData.find(p => p.slug === 'projects');
 
if (!projectsPage) return Astro.redirect('/');
const { Content } = await projectsPage.render();
---
<BaseLayout title="Projects | Personal Workspace">
  <main class="max-w-[1100px] mx-auto px-6 pb-24 pt-6">
    <Content />
  </main>
</BaseLayout>