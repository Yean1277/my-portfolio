---
/**
 * src/pages/index.astro
 *
 * Layout:
 *  1. HeroSection (100vh, full-bleed)  — Navigation + HeroTicker slotted inside
 *  2. 12-col grid
 *      col-4 sidebar: SidebarProfile + MusicPlayer
 *      col-8 main:    RecentPosts (replaces ProjectCollections)
 *  3. SiteFooter (full-bleed)
 */

import { getCollection } from 'astro:content';

import BaseLayout      from '../layouts/BaseLayout.astro';
import Navigation      from '../components/Navigation.astro';
import HeroSection     from '../components/HeroSection.astro';
import HeroTicker      from '../components/HeroTicker.astro';
import SidebarProfile  from '../components/SidebarProfile.astro';
import MusicPlayer     from '../components/MusicPlayer.astro';
import RecentPosts     from '../components/RecentPosts.astro';
import SiteFooter      from '../components/SiteFooter.astro';

// ── Data ─────────────────────────────────────────────────────────────────────
const allPosts = await getCollection('posts').catch(() => []);

const sortedPosts = [...allPosts].sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Ticker — 5 most recent post titles
const tickerPosts = sortedPosts.slice(0, 5).map(p => ({
  title: p.data.title,
  href:  `/posts/${p.slug}`,
  date:  p.data.date,
}));

// Footer tags + word count
const allTags    = allPosts.flatMap(p => p.data.tags ?? []);
const totalWords = allPosts.reduce((n, p) => n + (p.data.wordCount ?? 500), 0);

// ── Static config — edit these ────────────────────────────────────────────────
const profile = {
  name:           'Your Name',
  tagline:        'Frontend Developer · Anime Enjoyer',
  tags:           ['UI/UX', 'Astro', 'Next.js', 'Otaku'],
  currentFocus:   'Building portfolio with Astro + Three.js',
  avatarFallback: '/avatar.jpg',
};

---

<BaseLayout title="Portfolio — Where All Miracles Begin">

  <!-- 1 ── HERO ─────────────────────────────────────────────────────────── -->
  <HeroSection
    title="Your Name Here"
    tagline="所有奇迹的始发点 · Where All Miracles Begin"
    greeting="👋 Hey, welcome to my little corner of the web"
    wallpaper="/your-wallpaper.jpg"
    badge="HRO-001"
    liveLabel="LIVE"
  >
    <Navigation slot="nav" heroOverlay={true} />
    <HeroTicker
      slot="ticker"
      posts={tickerPosts}
      authorName="Your Name"
      authorAvatar="/avatar.jpg"
    />
  </HeroSection>

  <!-- 2 ── MAIN GRID ───────────────────────────────────────────────────── -->
  <div class="min-h-screen bg-[#f1f5f9] relative">

    <!-- Ambient glow — below the fold only -->
    <div
      class="fixed left-1/4 w-96 h-96 rounded-full blur-3xl pointer-events-none -z-10"
      style="top:100vh;background:rgba(57,197,187,0.05);"
      aria-hidden="true"
    ></div>

    <main class="max-w-[1100px] mx-auto px-6 pt-10 pb-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- Sidebar col-4 -->
        <aside class="lg:col-span-4 space-y-5">
          <SidebarProfile profile={profile} />
          <MusicPlayer />
        </aside>

        <!-- Main col-8 -->
        <section class="lg:col-span-8">
          <RecentPosts posts={sortedPosts} maxItems={8} />
        </section>

      </div>
    </main>
  </div>

  <!-- 3 ── FOOTER ──────────────────────────────────────────────────────── -->
  <SiteFooter
    postCount={allPosts.length}
    totalWords={totalWords}
    tags={allTags}
    startYear={2024}
  />

</BaseLayout>