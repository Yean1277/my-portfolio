---
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarProfile from '../components/SidebarProfile.astro';

// Dynamic Profile Data
const profile = {
  name: "Fidelity Designer",
  tagline: '"Interface is the bridge to the heart."',
  tags: ["UI/UX", "Astro", "Next.js", "Otaku"],
  currentFocus: "Neo-Interface Design",
  avatarFallback: "https://api.dicebear.com/7.x/adventurer/svg?seed=Fidelity"
};
---

<BaseLayout title="Portfolio // Fidelity System">
  <main class="max-w-[1100px] mx-auto px-6 pb-24 pt-12">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 w-full">
      
      <aside class="md:col-span-4">
        <SidebarProfile profile={profile} />
      </aside>

      <section class="md:col-span-8 border-2 border-dashed border-gray-300 rounded-[32px] flex items-center justify-center p-12 bg-white/50">
        <p class="text-gray-400 font-mono text-sm tracking-widest uppercase">Hero Banner Placeholder</p>
      </section>
      
    </div>
  </main>
</BaseLayout>