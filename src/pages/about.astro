---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getCollection } from 'astro:content';

const pageData = await getCollection('pageData');
const aboutPage = pageData.find(p => p.slug === 'about');

if (!aboutPage) return Astro.redirect('/');
const { Content } = await aboutPage.render();
---
<BaseLayout title="About | Personal Workspace">
  <Navigation />
  <main class="max-w-[1100px] mx-auto px-6 pb-16 pt-6">
    <Content />
  </main>
  <SiteFooter />
</BaseLayout>
