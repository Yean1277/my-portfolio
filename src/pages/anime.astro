---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getCollection } from 'astro:content';

const pageData = await getCollection('pageData');
const animePage = pageData.find((p: any) => p.slug === 'anime' || p.id === 'anime');

const baseAnimeData: {
  title: string;
  poster?: string;
  isPremium?: boolean;
  quote?: string;
}[] = animePage?.data?.animeList ?? [];

const entries = baseAnimeData.map((item, i) => ({
  ...item,
  poster:    item.poster ?? '',
  isPremium: item.isPremium ?? false,
  index:     i,
}));

const total = entries.length;
---

<BaseLayout title="Anime — Yean Ter">
  <Navigation />

  <!-- ── PAGE HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative bg-[#24231f] overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-32 -right-32 w-[560px] h-[560px] rounded-full blur-[120px]"
           style="background:rgba(57,197,187,0.07);"></div>
      <div class="absolute -bottom-16 -left-16 w-80 h-80 rounded-full blur-[80px]"
           style="background:rgba(240,117,53,0.06);"></div>
      <div class="absolute inset-0 opacity-[0.025]"
           style="background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:60px 60px;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 pt-20 pb-16">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">

        <div>
          <p class="text-[#39c5bb] text-[11px] font-semibold tracking-[0.35em] uppercase mb-4">
            Personal Archive
          </p>
          <h1 class="text-[72px] md:text-[100px] font-black leading-none tracking-tight text-white mb-5">
            アニメ
          </h1>
          <p class="text-white/40 text-[15px] max-w-sm leading-relaxed">
            Titles that left a mark — stories I still think about long after the credits roll.
          </p>
        </div>

        <div class="flex items-end gap-12 pb-1">
          <div>
            <p class="text-[52px] font-black leading-none text-white">{total}</p>
            <p class="text-white/30 text-[11px] tracking-[0.25em] uppercase mt-1">Titles</p>
          </div>
        </div>
      </div>

      <div class="mt-14 h-px bg-gradient-to-r from-[#39c5bb]/60 via-[#F07535]/25 to-transparent"></div>
    </div>
  </section>

  <!-- ── CARD GRID ───────────────────────────────────────────────────────────── -->
  <section class="bg-[#f7f6f2] min-h-screen">
    <div class="max-w-7xl mx-auto px-6 py-14">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3 sm:gap-5 lg:gap-6">

        {entries.map((anime) => (
          <div class="card-outer relative group" style={`--i:${anime.index}`}>

            <div class:list={[
              "absolute -inset-[2px] rounded-[22px] transition-all duration-500 pointer-events-none",
              anime.isPremium
                ? "premium-ring bg-gradient-to-br from-[#F07535] via-[#39c5bb] to-[#F07535]"
                : "opacity-0 group-hover:opacity-100 bg-gradient-to-br from-[#39c5bb]/60 to-[#F07535]/40",
            ]}></div>

            <div class="flip-inner w-full h-full relative [transform-style:preserve-3d] cursor-pointer">

              <div class="face-front absolute inset-0 rounded-[20px] shadow-lg overflow-hidden [backface-visibility:hidden]">

                <img
                  src={anime.poster || `https://picsum.photos/seed/${encodeURIComponent(anime.title)}/400/560`}
                  alt={anime.title}
                  class="poster-img w-full h-full object-cover object-top"
                  loading="lazy"
                  decoding="async"
                  onerror={`this.src='https://picsum.photos/seed/${encodeURIComponent(anime.title)}/400/560'`}
                />

                <div class="absolute inset-x-0 bottom-0 pt-14 pb-4 px-3
                            bg-gradient-to-t from-black/85 via-black/40 to-transparent">
                  <h3 class="text-white text-[11px] font-semibold leading-tight line-clamp-2">
                    {anime.title}
                  </h3>
                </div>


{anime.isPremium && (
                  <div class="absolute top-2.5 left-2.5 bg-gradient-to-r from-[#F07535] to-[#39c5bb] px-2 py-0.5 rounded-full">
                    <span class="text-white text-[8px] font-bold tracking-wider uppercase">★ Pick</span>
                  </div>
                )}
              </div>

              <div class="absolute inset-0 rounded-[20px] overflow-hidden shadow-xl flex flex-col
                          [backface-visibility:hidden] [transform:rotateY(180deg)]"
                   style="background:#1a1917;">

                <div class="h-1 w-full bg-gradient-to-r from-[#39c5bb] to-[#F07535] flex-shrink-0"></div>

                <div class="flex-1 flex flex-col justify-center items-center px-5 py-6 relative overflow-hidden">
                  <div class="absolute -top-3 left-1 text-[110px] leading-none font-serif
                               select-none pointer-events-none text-[#39c5bb]/8">"</div>
                  <div class="absolute -bottom-8 right-1 text-[110px] leading-none font-serif
                               select-none pointer-events-none text-[#F07535]/8 rotate-180">"</div>

                  {anime.quote ? (
                    <p class="card-quote relative z-10 text-white/80 text-[11px] italic leading-relaxed text-center">
                      {anime.quote}
                    </p>
                  ) : (
                    <p class="card-quote relative z-10 text-white/25 text-[10px] italic text-center">
                      No quote yet...
                    </p>
                  )}
                </div>

                <div class="px-4 pb-5">
                  <div class="border-t pt-3 flex flex-col gap-2" style="border-color:rgba(255,255,255,0.06);">
                    <p class="text-[9px] text-white/35 text-center leading-snug line-clamp-2">
                      {anime.title}
                    </p>
                    <div class="flex items-center justify-center gap-2">
                      <div class="w-4 h-px bg-[#39c5bb]/40 rounded-full"></div>
                      <p class="text-[8px] text-white/20 tracking-[0.2em] uppercase">tap to flip</p>
                      <div class="w-4 h-px bg-[#39c5bb]/40 rounded-full"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <SiteFooter />
</BaseLayout>

<style>
  @keyframes pulse-border {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }
  .premium-ring { animation: pulse-border 2.5s ease-in-out infinite; }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }

  .card-outer {
    perspective: 1000px;
    width: 100%;
    aspect-ratio: 5 / 7;
    animation: card-in 0.45s ease both;
    animation-delay: min(calc(var(--i) * 75ms), 350ms);
  }

  .flip-inner {
    transition: transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 16px rgba(36, 35, 31, 0.12);
  }

  .flip-inner.flipped {
    transform: rotateY(180deg);
  }

  .card-quote {
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    transition-delay: 0s;
  }
  .flip-inner.flipped .card-quote {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.35s;
  }

  .poster-img {
    transition: transform 0.7s ease;
  }

  /* Hover effects only on devices that support true hover (not iOS sticky-hover) */
  @media (hover: hover) and (pointer: fine) {
    .card-outer:hover .flip-inner:not(.flipped) {
      transform: translateY(-7px) scale(1.03);
      box-shadow: 0 20px 48px rgba(36, 35, 31, 0.22), 0 0 0 1px rgba(57, 197, 187, 0.08);
    }
    .card-outer:hover .flip-inner:not(.flipped) .poster-img {
      transform: scale(1.07);
    }
  }

  /* Touch tap feedback */
  @media (hover: none) {
    .card-outer:active .flip-inner:not(.flipped) {
      transform: scale(0.96);
      transition: transform 0.1s ease;
    }
  }

  /* Fast transition during tilt tracking; spring curve kicks back in on mouseleave */
  .flip-inner.tilting {
    transition: transform 0.08s linear,
                box-shadow 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>

<script>
  const MAX_TILT  = 10;
  const canHover  = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  document.querySelectorAll<HTMLElement>('.card-outer').forEach(card => {
    const inner = card.querySelector<HTMLElement>('.flip-inner');
    if (!inner) return;

    if (canHover) {
      card.addEventListener('mouseenter', () => inner.classList.add('tilting'));

      card.addEventListener('mousemove', (e) => {
        if (inner.classList.contains('flipped')) return;
        const rect = card.getBoundingClientRect();
        const dx = (e.clientX - (rect.left + rect.width  / 2)) / (rect.width  / 2);
        const dy = (e.clientY - (rect.top  + rect.height / 2)) / (rect.height / 2);
        inner.style.transform =
          `translateY(-7px) scale(1.03) rotateX(${-dy * MAX_TILT}deg) rotateY(${dx * MAX_TILT}deg)`;
      });

      card.addEventListener('mouseleave', () => {
        inner.classList.remove('tilting');
        inner.style.transform = '';
      });
    }

    inner.addEventListener('click', () => {
      inner.style.transform = '';
      inner.classList.toggle('flipped');
    });
  });
</script>
