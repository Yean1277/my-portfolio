---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 获取动漫页面内容
const pages = await getCollection('pages');
// 兼容 Astro 5.x 的 id 属性和 旧版的 slug
const animePage = pages.find((p: any) => p.slug === 'anime' || p.id === 'anime');
const Content = animePage ? (await animePage.render()).Content : null;

// 从 MDX 的 frontmatter 中读取动漫数据列表
const baseAnimeData = animePage?.data?.animeList || [];

// 如果数据较少，将其扩充以填满 3D 星系背景（建议至少 30-50 张卡片效果最佳）
const targetCount = 48;
const repeatCount = baseAnimeData.length > 0 ? Math.ceil(targetCount / baseAnimeData.length) : 0;

// 铺满计算
const animeData = baseAnimeData.length > 0 
  ? Array(repeatCount).fill(baseAnimeData).flat().slice(0, targetCount).map((item, index) => ({
      ...item,
      id: index
    }))
  : [];
---

<BaseLayout title="动漫收藏 | 沉浸式星系">
  <!-- 替换为纯白背景 bg-white -->
  <div id="anime-gallery" class="w-full h-screen relative overflow-hidden bg-white">
    
    <!-- 3D 渲染容器 -->
    <canvas id="three-canvas" class="w-full h-full absolute inset-0 z-0" data-anime={JSON.stringify(animeData)}></canvas>


    <!-- 详情弹出层：修改为亮色磨砂，并修复 Flex 撑爆 Bug -->
    <div id="detail-overlay" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500 bg-white/50 backdrop-blur-md p-4">
      <div class="bg-white/90 backdrop-blur-xl border border-gray-200 w-full max-w-4xl h-auto max-h-[90vh] md:h-[70vh] rounded-3xl p-6 relative flex flex-col md:flex-row gap-8 transform scale-95 transition-transform duration-500 shadow-2xl overflow-y-auto md:overflow-hidden" id="detail-card">
        
        <button id="close-detail" class="absolute top-4 right-4 p-2 rounded-full bg-gray-100 hover:bg-[#39C5BB]/10 text-gray-500 hover:text-[#39C5BB] transition-colors z-10">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <!-- 【核心修复点】: 使用 relative + absolute inset-0，以及 flex-shrink-0 彻底锁死图片尺寸 -->
        <div class="w-full md:w-1/2 h-[40vh] md:h-full rounded-2xl overflow-hidden shadow-md bg-gray-50 border border-gray-100 flex-shrink-0 relative">
          <!-- 图片无论比例多怪，都会被死死按在这个框里 -->
          <img id="detail-image" src="" alt="Anime Cover" class="absolute inset-0 w-full h-full object-contain md:object-cover opacity-0 transition-opacity duration-500" />
        </div>

        <div class="w-full md:w-1/2 flex flex-col justify-center py-4">
          <div class="inline-block px-3 py-1 rounded-full bg-[#39C5BB]/10 text-[#39C5BB] text-xs font-bold tracking-wider mb-4 w-max border border-[#39C5BB]/30">SELECTED SERIES</div>
          <h2 id="detail-title" class="text-3xl font-bold text-gray-900 mb-4 leading-tight font-serif">动漫标题</h2>
          <p class="text-gray-600 text-sm mb-8 leading-relaxed italic">“这不仅仅是一个补番记录，更是一个属于你的动漫回忆星系。点击任意卡片查看详细信息。”</p>
          
          <div class="space-y-4">
            <div class="flex justify-between border-b border-gray-200 pb-3">
              <span class="text-gray-500 text-sm">观看编号</span>
              <span id="detail-id" class="text-[#39C5BB] text-sm font-bold font-mono">#000</span>
            </div>
            <div class="flex justify-between border-b border-gray-200 pb-3">
              <span class="text-gray-500 text-sm uppercase tracking-tighter">Status</span>
              <span class="text-gray-800 text-sm font-medium">收藏中</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 页面下方的正文内容：移除了 prose-invert，适应亮色主题 -->
  {Content && (
    <main class="container mx-auto px-4 mt-16 mb-24 prose max-w-4xl">
      <Content />
    </main>
  )}
</BaseLayout>

<script>
  import * as THREE from 'three';
  // 如果这里报错，可以试试改为 from 'three/addons/controls/OrbitControls.js'
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';
  import * as TWEEN from '@tweenjs/tween.js';

  document.addEventListener('DOMContentLoaded', () => {
    initThreeJS();
  });

  function initThreeJS() {
    const canvas = document.getElementById('three-canvas') as HTMLCanvasElement;
    const animeData = JSON.parse(canvas.dataset.anime || '[]');
    
    if (animeData.length === 0) return;

    const scene = new THREE.Scene();
    // 修改为纯白背景和白雾
    scene.background = new THREE.Color('#ffffff');
    scene.fog = new THREE.FogExp2('#ffffff', 0.0008);

    const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 1, 10000);
    camera.position.set(0, 500, 1800);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(window.innerWidth, window.innerHeight);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.autoRotate = true; 
    controls.autoRotateSpeed = 0.4;
    controls.maxDistance = 3000;
    controls.minDistance = 500;

    // 灯光：提升全局亮度和添加初音绿点光
    scene.add(new THREE.AmbientLight(0xffffff, 0.9));
    const mikuLight = new THREE.PointLight(0x39C5BB, 2, 3000);
    mikuLight.position.set(500, 500, 500);
    scene.add(mikuLight);

    // 星尘系统：白底上白色星星看不见，所以改用初音绿的粒子，增加通透感
    const starCount = 2000;
    const starGeo = new THREE.BufferGeometry();
    const starPos = new Float32Array(starCount * 3);
    for(let i=0; i<starCount; i++) {
        starPos[i*3] = (Math.random() - 0.5) * 5000;
        starPos[i*3+1] = (Math.random() - 0.5) * 5000;
        starPos[i*3+2] = (Math.random() - 0.5) * 5000;
    }
    starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
    const starMat = new THREE.PointsMaterial({ color: 0x39C5BB, size: 2.5, transparent: true, opacity: 0.5 });
    scene.add(new THREE.Points(starGeo, starMat));

    // 卡片生成
    const cardGroup = new THREE.Group();
    scene.add(cardGroup);
    const textureLoader = new THREE.TextureLoader();
    textureLoader.setCrossOrigin('anonymous');
    const cardGeometry = new THREE.PlaneGeometry(130, 182);

    animeData.forEach((data: any, i: number) => {
        // 卡片底色改为纯白
        const material = new THREE.MeshPhysicalMaterial({ 
            color: 0xffffff,
            side: THREE.DoubleSide,
            roughness: 0.2,
            metalness: 0.1
        });

        const card = new THREE.Mesh(cardGeometry, material);
        card.userData = { id: i, title: data.title, image: data.poster };
        
        // 星系螺旋算法
        const angle = i * 0.4;
        const radius = 250 + (i * 25);
        const x = Math.cos(angle) * radius;
        const z = Math.sin(angle) * radius;
        const y = (Math.random() - 0.5) * 300;

        card.position.set(x, y, z);
        card.lookAt(0, y, 0);
        cardGroup.add(card);

        // 异步加载海报
        textureLoader.load(data.poster, (tex) => {
            material.map = tex;
            material.needsUpdate = true;
        });
    });

    // 交互逻辑保持不变
    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();
    let hovered: THREE.Mesh | null = null;

    canvas.addEventListener('mousemove', (e) => {
        mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
        mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
    });

    const overlay = document.getElementById('detail-overlay')!;
    const dTitle = document.getElementById('detail-title')!;
    const dImg = document.getElementById('detail-image') as HTMLImageElement;
    const dId = document.getElementById('detail-id')!;

    canvas.addEventListener('click', () => {
        if(hovered) {
            const d = hovered.userData;
            dTitle.innerText = d.title;
            dId.innerText = `#${String(d.id + 1).padStart(3, '0')}`;
            dImg.src = d.image;
            dImg.onload = () => dImg.classList.remove('opacity-0');
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            controls.autoRotate = false;
        }
    });

    document.getElementById('close-detail')?.addEventListener('click', () => {
        overlay.classList.add('opacity-0', 'pointer-events-none');
        controls.autoRotate = true;
        setTimeout(() => dImg.classList.add('opacity-0'), 500);
    });

    function animate() {
        requestAnimationFrame(animate);
        TWEEN.update();
        controls.update();

        raycaster.setFromCamera(mouse, camera);
        const intersects = raycaster.intersectObjects(cardGroup.children);

        if (intersects.length > 0) {
            const target = intersects[0].object as THREE.Mesh;
            if (hovered !== target) {
                if (hovered) hovered.scale.set(1, 1, 1);
                hovered = target;
                canvas.style.cursor = 'pointer';
                new TWEEN.Tween(hovered.scale).to({ x: 1.2, y: 1.2, z: 1.2 }, 200).start();
            }
        } else if (hovered) {
            new TWEEN.Tween(hovered.scale).to({ x: 1, y: 1, z: 1 }, 200).start();
            hovered = null;
            canvas.style.cursor = 'auto';
        }

        renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });
  }
</script>