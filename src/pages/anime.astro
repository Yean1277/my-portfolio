---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import { getCollection } from 'astro:content';

// ── Data ──────────────────────────────────────────────────────────────────────
const pageData = await getCollection('pageData');
const animePage = pageData.find((p: any) => p.slug === 'anime' || p.id === 'anime');

const Content = animePage ? (await animePage.render()).Content : null;

const baseAnimeData: { title: string; poster?: string; isPremium?: boolean }[] =
  animePage?.data?.animeList ?? [];

const entries = baseAnimeData.map((item, i) => ({
  ...item,
  poster:       item.poster ?? '',
  isPremium:    item.isPremium ?? false,
  serialNumber: `03-ANM-${String(i + 1).padStart(3, '0')}`,
}));

const title: string = animePage?.data?.title ?? '我看过的动漫';
const total = entries.length;
---

<BaseLayout>

  <Navigation/>
  <div class="min-h-screen bg-[#f1f5f9] text-slate-800 p-8">

    <!-- ── MDX body prose ──────────────────────────────────────────────────── -->
    {Content && (
      <div class="max-w-7xl mx-auto mb-10 prose prose-slate text-sm">
        <Content />
      </div>
    )}

    <!-- ── Card grid ───────────────────────────────────────────────────────── -->
    <main class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-8 justify-items-center">
      {entries.map((anime) => (
        <div class="relative group w-[220px] h-[308px] transition-all duration-300 hover:-translate-y-2">

          <!-- Gradient border ring -->
          <div class:list={[
            "absolute -inset-[3px] rounded-[24px] transition-all duration-500",
            anime.isPremium
              ? "premium-ring bg-gradient-to-br from-orange-400 via-[#39c5bb] to-orange-400"
              : "bg-gradient-to-br from-[#39c5bb]/40 to-orange-300/40",
          ]}></div>

          <!-- Card body -->
          <div class="relative h-full w-full bg-white rounded-[20px] p-[5px] flex flex-col shadow-xl overflow-hidden border border-slate-200">
            <div class="relative flex-1 rounded-[16px] overflow-hidden flex flex-col bg-[#f8fafc]">

              <!-- Poster -->
              <div class="relative flex-1 overflow-hidden">
                <img
                  src={anime.poster || `https://picsum.photos/seed/${encodeURIComponent(anime.title)}/600/840`}
                  alt={anime.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                  decoding="async"
                  onerror={`this.src='https://picsum.photos/seed/${encodeURIComponent(anime.title)}/600/840'`}
                />

                <!-- CV badge -->
                <div class="absolute top-2 left-2 px-2 py-0.5 bg-[#39c5bb]/90 backdrop-blur-sm rounded-md border border-white/20">
                  <span class="text-[9px] font-black text-white italic">CV:01</span>
                </div>

                <!-- Serial badge -->
                <div class="absolute top-2 right-2 px-2 py-0.5 bg-orange-500/90 backdrop-blur-sm rounded-md border border-white/20">
                  <span class="text-[9px] font-mono text-white font-bold">{anime.serialNumber}</span>
                </div>

                <!-- Fade -->
                <div class="absolute inset-x-0 bottom-0 h-12 bg-gradient-to-t from-white via-white/20 to-transparent"></div>
              </div>

              <!-- Title area -->
              <div class="px-3 py-3 bg-white relative">
                <div class="absolute right-2 bottom-2 opacity-5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/>
                  </svg>
                </div>

                <div class="relative z-10 flex flex-col gap-0.5">
                  <div class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2 text-[#39c5bb]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/>
                      <line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/>
                    </svg>
                    <span class="text-[8px] text-[#39c5bb] font-bold tracking-widest">ANIME_COLLECTION</span>
                  </div>
                  <h3 class="text-[11px] font-black text-slate-800 line-clamp-2 leading-tight tracking-tight">
                    {anime.title}
                  </h3>
                </div>
              </div>

            </div>
          </div>

          <!-- Hover shimmer -->
          <div class="pointer-events-none absolute inset-0 rounded-[20px] bg-gradient-to-br from-white/0 via-orange-100/20 to-[#39c5bb]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      ))}
    </main>

    <!-- ── Footer ──────────────────────────────────────────────────────────── -->
    <footer class="max-w-7xl mx-auto mt-20 border-t border-slate-200 pt-8 text-center">
      <div class="flex items-center justify-center gap-2 text-slate-400 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
          stroke="currentColor" stroke-width="2"><path d="M3 20L12 4l9 16H3z"/><path d="M12 4v8"/></svg>
        <span class="text-[10px] tracking-[0.4em] uppercase font-bold">Anime × Virtual Archive</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
          stroke="currentColor" stroke-width="2">
          <path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/>
        </svg>
      </div>
      <p class="text-[9px] text-slate-400">© 2024 Miku Camp Design — {total} entries · anime.astro</p>
    </footer>

  </div>
</BaseLayout>

<style>
  @keyframes pulse-border {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }
  .premium-ring { animation: pulse-border 2s ease-in-out infinite; }
</style>