---
const { pathname } = Astro.url;

const links = [
  { href: '/',         label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/anime',    label: 'Anime Labs', badge: 'New' },
  { href: '/resume',   label: 'Resume' },
  { href: '/about',    label: 'About' },
];
---
<nav class="max-w-[1100px] mx-auto flex justify-between items-center mb-12 px-6 pt-10">
  <!-- Logo: teal gradient text -->
  <div class="text-2xl font-black tracking-tight bg-gradient-to-r from-[#39c5bb] to-[#2ba8a0] bg-clip-text text-transparent">
    PORTFOLIO
  </div>

  <!-- Nav links -->
  <div class="hidden md:flex space-x-8 font-medium text-[13px] text-slate-500 items-center">
    {links.map(({ href, label, badge }) => {
      const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href);
      return (
        <div class="flex flex-col items-center">
          <a
            href={href}
            class:list={[
              'flex items-center gap-1 transition-colors',
              isActive ? 'text-[#39c5bb] font-bold' : 'hover:text-slate-900',
            ]}
          >
            {label}
            {badge && (
              <span class="text-[8px] bg-orange-100 text-orange-500 font-black px-1.5 py-0.5 rounded-full uppercase tracking-wide">
                {badge}
              </span>
            )}
          </a>
          {isActive && <div class="w-3 h-[2px] bg-[#39c5bb] mt-1 rounded-full"></div>}
        </div>
      );
    })}
  </div>

  <div class="flex items-center gap-4">
    <!-- CTA button: slate dark with teal hover glow -->
    <button class="bg-slate-900 text-white px-6 py-2.5 rounded-full text-[13px] font-bold hover:scale-105 hover:shadow-[0_4px_20px_rgba(57,197,187,0.3)] transition-all duration-200">
      Contact
    </button>
  </div>
</nav>
