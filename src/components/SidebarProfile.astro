---
interface Props {
  profile: {
    name: string;
    tagline: string;
    tags: string[];
    currentFocus: string;
    avatarFallback: string;
  };
}

const { profile } = Astro.props;
---
<div class="bg-white rounded-[32px] p-8 flex flex-col items-center text-center shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
  <div class="relative w-[110px] h-[110px] mb-5 group cursor-pointer" id="profilePicContainer">
    <div id="avatar-loader" class="absolute inset-0 z-10 loading-shimmer rounded-full hidden"></div>
    <img
      id="profilePic"
      src={profile.avatarFallback}
      alt={profile.name}
      class="w-full h-full object-cover rounded-full shadow-sm group-hover:scale-105 transition-transform duration-300"
    />
    <div class="absolute bottom-1 right-1 w-6 h-6 bg-primary border-[4px] border-white rounded-full"></div>
  </div>

  <h1 class="text-2xl font-bold mb-1 text-gray-900">{profile.name}</h1>
  <p class="text-gray-400 text-[13px] mb-6 italic">{profile.tagline}</p>

  <div class="flex flex-wrap justify-center gap-3 mb-8">
  {profile.tags.map((tag) => (
    <span class="bg-blue-50 text-blue-500 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest border border-blue-100">
      {tag}
    </span>
  ))}
</div>

  <div class="w-full text-left pt-6 border-t border-gray-100">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Directory / Pages</p>
    <div class="space-y-3">
      <div class="flex items-center gap-3 text-[13px] text-gray-600 font-mono">
        <div class="w-2 h-2 rounded-full bg-[#6EE7B7]"></div> anime.astro
      </div>
      <div class="flex items-center gap-3 text-[13px] text-gray-600 font-mono">
        <div class="w-2 h-2 rounded-full bg-[#60A5FA]"></div> projects.astro
      </div>
    </div>
  </div>
</div>