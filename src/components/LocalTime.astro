---
/**
 * LocalTime.astro
 * Small sidebar card showing the current local time.
 * Sits ABOVE SidebarProfile in the sidebar column.
 *
 * Props:
 *   label    — top label, e.g. "LOCAL TIME · CHINA"
 *   timezone — IANA tz string used for clock + date (default "Asia/Shanghai")
 */

interface Props {
  label?:    string;
  timezone?: string;
}

const {
  label    = 'LOCAL TIME · CHINA',
  timezone = 'Asia/Shanghai',
} = Astro.props;
---

<div
  id="local-time-card"
  data-tz={timezone}
  class="bg-white rounded-2xl border border-slate-100 px-5 py-4 flex items-center gap-4 shadow-[0_4px_20px_rgba(15,23,42,0.04)]"
  style="font-family:'Plus Jakarta Sans',sans-serif;"
>
  <!-- Clock icon (teal ring + hands) -->
  <div class="w-10 h-10 rounded-full bg-[#39c5bb]/10 border border-[#39c5bb]/30 flex items-center justify-center shrink-0">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke="#39c5bb" stroke-width="1.6"/>
      <path d="M12 7V12L15 14" stroke="#39c5bb" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <div class="flex-1 min-w-0">
    <p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.18em] mb-0.5">{label}</p>
    <p
      id="lt-time"
      class="text-[18px] font-black text-slate-900 tabular-nums leading-none"
      style="font-family:'JetBrains Mono','Plus Jakarta Sans',monospace;letter-spacing:0.04em;"
    >
      00:00:00
    </p>
    <p id="lt-date" class="text-[10px] text-slate-400 font-medium mt-1 tabular-nums">—</p>
  </div>
</div>

<script>
  const card = document.getElementById('local-time-card');
  const timeEl = document.getElementById('lt-time');
  const dateEl = document.getElementById('lt-date');
  const tz = card?.dataset.tz || 'Asia/Shanghai';

  function pad(n: number) { return n.toString().padStart(2, '0'); }

  function tick() {
    const now = new Date();

    // Time as HH:MM:SS in given timezone
    const timeFmt = new Intl.DateTimeFormat('en-GB', {
      timeZone: tz,
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    });
    if (timeEl) timeEl.textContent = timeFmt.format(now);

    // Short date e.g. "Mon, May 4"
    const dateFmt = new Intl.DateTimeFormat('en-US', {
      timeZone: tz,
      weekday: 'short',
      month:   'short',
      day:     'numeric',
    });
    if (dateEl) dateEl.textContent = dateFmt.format(now);
  }

  tick();
  setInterval(tick, 1000);
</script>