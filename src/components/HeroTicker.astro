---
/**
 * HeroTicker.astro
 * Frosted-glass strip pinned to the bottom of HeroSection.
 * Shows the N most recent posts as a mini-carousel with prev/next controls.
 *
 * Usage (inside HeroSection's "ticker" slot):
 *   <HeroTicker slot="ticker" posts={recentPosts} authorName="Your Name" authorAvatar="/avatar.jpg" />
 *
 * Props:
 *   posts        — array of { title, href, date } — pull from getCollection('posts')
 *   authorName   — shown beside avatar
 *   authorAvatar — path to avatar image
 *   maxItems     — how many posts to show in the carousel (default 5)
 */

interface TickerPost {
  title: string;
  href: string;
  date: Date | string;
}

interface Props {
  posts: TickerPost[];
  authorName?: string;
  authorAvatar?: string;
  maxItems?: number;
}

const {
  posts,
  authorName = 'Portfolio',
  authorAvatar,
  maxItems = 5,
} = Astro.props;

// Slice to maxItems and format relative dates
const items = posts.slice(0, maxItems).map((p) => {
  const d = new Date(p.date);
  const diffMs = Date.now() - d.getTime();
  const diffDays = Math.floor(diffMs / 86400000);
  let rel: string;
  if (diffDays === 0)       rel = 'Today';
  else if (diffDays === 1)  rel = 'Yesterday';
  else if (diffDays < 7)   rel = `${diffDays}d ago`;
  else if (diffDays < 30)  rel = `${Math.floor(diffDays / 7)}w ago`;
  else if (diffDays < 365) rel = `${Math.floor(diffDays / 30)}mo ago`;
  else                      rel = `${Math.floor(diffDays / 365)}y ago`;
  return { ...p, rel };
});

// Fallback items if no posts
const displayItems = items.length > 0 ? items : [
  { title: 'Welcome to my portfolio — building things with Astro & Three.js', href: '/', rel: 'Now' },
  { title: 'Exploring anime aesthetics in UI design systems', href: '/anime', rel: '1w ago' },
];
---

<!-- Ticker bar — absolute bottom of HeroSection, full width -->
<div
  id="hero-ticker"
  class="absolute bottom-0 left-0 right-0 z-20"
  style="background: rgba(0,0,0,0.38); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-top: 1px solid rgba(255,255,255,0.08);"
>
  <div class="max-w-[1100px] mx-auto px-6 py-3 flex items-center gap-4">

    <!-- Left: Author avatar + name -->
    <div class="flex items-center gap-2.5 shrink-0">
      <div class="relative">
        {authorAvatar ? (
          <img
            src={authorAvatar}
            alt={authorName}
            class="w-8 h-8 rounded-full object-cover border border-white/20"
          />
        ) : (
          <!-- Initials fallback -->
          <div
            class="w-8 h-8 rounded-full flex items-center justify-center border border-white/20 text-[10px] font-black text-white"
            style="background: linear-gradient(135deg, #39c5bb, #2ba8a0);"
          >
            {authorName.slice(0, 2).toUpperCase()}
          </div>
        )}
        <!-- Online pulse dot -->
        <span
          class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full bg-[#39c5bb] border-2 border-black/40 animate-pulse"
          aria-hidden="true"
        ></span>
      </div>

      <span class="text-white/70 text-[12px] font-semibold hidden sm:block" style="font-family:'Plus Jakarta Sans',sans-serif;">
        {authorName}
      </span>
    </div>

    <!-- Divider -->
    <div class="w-px h-5 bg-white/15 shrink-0 hidden sm:block"></div>

    <!-- Center: Scrolling post title carousel -->
    <div class="flex-1 overflow-hidden relative" style="min-width: 0;">
      <div id="ticker-track" class="flex flex-col">
        {displayItems.map((item, i) => (
          <a
            href={item.href}
            class:list={[
              'ticker-item flex items-center gap-3 transition-all duration-500',
              i === 0 ? 'opacity-100 translate-y-0' : 'opacity-0 absolute top-0 translate-y-2 pointer-events-none',
            ]}
            data-ticker-idx={i}
            style="height: 2rem; line-height: 2rem;"
          >
            <!-- Category dot -->
            <span class="w-1.5 h-1.5 rounded-full bg-[#39c5bb] shrink-0" aria-hidden="true"></span>

            <!-- Title — truncated -->
            <span
              class="text-white/90 text-[13px] font-medium truncate hover:text-white transition-colors"
              style="font-family:'Plus Jakarta Sans',sans-serif;"
            >
              {item.title}
            </span>

            <!-- Timestamp pill -->
            <span class="shrink-0 text-[10px] text-white/40 font-mono hidden md:block">
              {item.rel}
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Right: Prev / Next / Play controls -->
    <div class="flex items-center gap-1.5 shrink-0">
      <!-- Prev -->
      <button
        id="ticker-prev"
        aria-label="Previous post"
        class="w-7 h-7 rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-white/10 transition-all"
      >
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M7 1L3 5L7 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Post counter -->
      <span id="ticker-counter" class="text-[10px] font-mono text-white/35 w-8 text-center tabular-nums">
        1/{displayItems.length}
      </span>

      <!-- Next -->
      <button
        id="ticker-next"
        aria-label="Next post"
        class="w-7 h-7 rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-white/10 transition-all"
      >
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M3 1L7 5L3 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Divider -->
      <div class="w-px h-4 bg-white/15 mx-1"></div>

      <!-- Auto-play toggle -->
      <button
        id="ticker-play"
        aria-label="Toggle auto-advance"
        aria-pressed="true"
        class="w-7 h-7 rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-white/10 transition-all"
      >
        <!-- Play icon (shown when paused) -->
        <svg id="icon-play" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true" class="hidden">
          <path d="M2 1.5L8 5L2 8.5V1.5Z" fill="currentColor"/>
        </svg>
        <!-- Pause icon (shown when playing) -->
        <svg id="icon-pause" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <rect x="2" y="1.5" width="2.5" height="7" rx="0.5" fill="currentColor"/>
          <rect x="5.5" y="1.5" width="2.5" height="7" rx="0.5" fill="currentColor"/>
        </svg>
      </button>
    </div>

  </div>
</div>

<script>
  const items   = document.querySelectorAll<HTMLAnchorElement>('.ticker-item');
  const prevBtn = document.getElementById('ticker-prev')!;
  const nextBtn = document.getElementById('ticker-next')!;
  const playBtn = document.getElementById('ticker-play')!;
  const counter = document.getElementById('ticker-counter')!;
  const iconPlay  = document.getElementById('icon-play')!;
  const iconPause = document.getElementById('icon-pause')!;

  const total = items.length;
  let current = 0;
  let playing = true;
  let timer: ReturnType<typeof setInterval>;

  function show(idx: number) {
    const prev = current;
    current = ((idx % total) + total) % total;

    // Outgoing
    items[prev].classList.remove('opacity-100', 'translate-y-0');
    items[prev].classList.add('opacity-0', 'translate-y-2', 'pointer-events-none', 'absolute');

    // Incoming
    items[current].classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none', 'absolute');
    items[current].classList.add('opacity-100', 'translate-y-0');

    counter.textContent = `${current + 1}/${total}`;
  }

  function startTimer() {
    clearInterval(timer);
    if (playing && total > 1) {
      timer = setInterval(() => show(current + 1), 4000);
    }
  }

  prevBtn.addEventListener('click', () => { show(current - 1); startTimer(); });
  nextBtn.addEventListener('click', () => { show(current + 1); startTimer(); });

  playBtn.addEventListener('click', () => {
    playing = !playing;
    playBtn.setAttribute('aria-pressed', String(playing));
    iconPlay.classList.toggle('hidden',  playing);
    iconPause.classList.toggle('hidden', !playing);
    startTimer();
  });

  startTimer();
</script>