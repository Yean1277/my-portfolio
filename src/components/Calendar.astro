---
const monthNames = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
const days = ['月', '火', '水', '木', '金', '土', '日'];
const currentMonth = new Date(2026, 2); // March 2026
---
<!-- DEPRECATED: This component uses the old pastel design system (wisteria/celadon/sakura colors).
     The Fidelity design system (teal #39C5BB) is now the canonical design.
     This component is not used in the current Fidelity-based pages. -->
<section class="rounded-[28px] border border-[#e9dfee] bg-white/95 p-6 shadow-soft">
  <div class="flex items-center justify-between mb-4">
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-[#8d748f]">Calendar</p>
      <h3 class="mt-2 text-xl font-semibold text-[#3f3240]">{currentMonth.getFullYear()} {monthNames[currentMonth.getMonth()]}</h3>
    </div>
    <div class="flex items-center gap-2 text-lg text-[#8d748f]">
      <button class="rounded-2xl bg-mist-violet-soft px-3 py-2 transition hover:bg-sakura-soft">‹</button>
      <button class="rounded-2xl bg-mist-violet-soft px-3 py-2 transition hover:bg-sakura-soft">›</button>
    </div>
  </div>
  <div class="calendar-grid text-[11px] text-center text-[#7b6d66] mb-3">
    {days.map((day) => (
      <div class={days.indexOf(day) >= 5 ? 'text-[#9d7f8f]' : ''}>{day}</div>
    ))}
  </div>
  <div class="calendar-grid text-[13px] text-center">
    {Array.from({ length: 31 }, (_, i) => (
      <div class="rounded-2xl bg-surface px-2 py-2 transition hover:bg-sakura-soft">{i + 1}</div>
    ))}
  </div>
</section>
