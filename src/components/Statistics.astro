<section class="rounded-[28px] border border-[#e9dfee] bg-white/95 p-6 shadow-soft">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-[#3f3240]">統計情報</h3>
    <span class="rounded-full bg-sakura-soft px-3 py-1 text-xs text-[#87566f]">Live</span>
  </div>
  <div class="space-y-4 text-sm text-[#6f5f60]">
    <div class="rounded-[20px] bg-mist-violet-soft px-4 py-3 flex items-center justify-between">
      <span>📝 投稿</span>
      <span class="font-semibold text-[#3f3240]">6</span>
    </div>
    <div class="rounded-[20px] bg-sakura-soft px-4 py-3 flex items-center justify-between">
      <span>📁 カテゴリー</span>
      <span class="font-semibold text-[#3f3240]">3</span>
    </div>
    <div class="rounded-[20px] bg-celadon-soft px-4 py-3 flex items-center justify-between">
      <span>🏷️ タグ</span>
      <span class="font-semibold text-[#3f3240]">10</span>
    </div>
    <div class="rounded-[20px] bg-rose-fog-soft px-4 py-3 flex items-center justify-between">
      <span>⌨️ 文字数合計</span>
      <span class="font-semibold text-[#3f3240]">2,431</span>
    </div>
    <div class="rounded-[20px] bg-honey-soft px-4 py-3 flex items-center justify-between">
      <span>📅 稼働日数</span>
      <span class="font-semibold text-[#3f3240]">449日</span>
    </div>
  </div>
</section>
