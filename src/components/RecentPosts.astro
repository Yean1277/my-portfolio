---
/**
 * RecentPosts.astro
 * Full-width post list for the main col-8 area.
 * Each row: left accent bar + category badge + title + excerpt + thumbnail right.
 * Mirrors kfdzcoffee 最新动态 style.
 */

interface Post {
  slug: string;
  data: {
    title: string;
    description?: string;
    date: Date | string;
    category?: string;
    tags?: string[];
    heroImage?: string;
  };
}

interface Props {
  posts: Post[];
  maxItems?: number;
}

const { posts, maxItems = 8 } = Astro.props;

const fmt = (d: Date | string) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const items = posts.slice(0, maxItems).map((p, i) => ({
  title:    p.data.title,
  excerpt:  p.data.description ?? '',
  href:     `/posts/${p.slug}`,
  date:     fmt(p.data.date),
  category: p.data.category ?? 'Post',
  tags:     (p.data.tags ?? []).slice(0, 2),
  image:    p.data.heroImage ?? null,
  idx:      i,
}));

const demo = [
  { title: 'My Top 5 Anime This Season',           excerpt: 'Ranked by vibe, animation quality, and whether I actually cried.',                                         href: '#', date: 'May 1, 2026',  category: 'Anime',   tags: ['ACGN', 'Review'],    image: null, idx: 0 },
  { title: 'Designing Card-Based UI Systems',       excerpt: 'Gradient rings, shimmer overlays, and composable components in Astro.',                                    href: '#', date: 'Apr 24, 2026', category: 'Design',  tags: ['UI', 'Astro'],       image: null, idx: 1 },
  { title: 'Building a Music Player in Astro',      excerpt: 'No framework JS — just Astro islands and a spinning vinyl record made from plain SVG.',                   href: '#', date: 'Apr 17, 2026', category: 'Dev',     tags: ['Astro', 'Audio'],    image: null, idx: 2 },
  { title: 'Honkai: Star Rail Lore Deep Dive',      excerpt: 'Catching up before the next arc. Spoilers for Penacony. Why is Firefly so good.',                         href: '#', date: 'Apr 10, 2026', category: 'Anime',   tags: ['ACGN', 'Honkai'],    image: null, idx: 3 },
  { title: 'Three.js Particle Systems on a Budget', excerpt: '60fps star-field effects without a beefy GPU — instanced mesh and frustum culling.',                      href: '#', date: 'Apr 3, 2026',  category: 'Dev',     tags: ['Three.js', 'WebGL'], image: null, idx: 4 },
  { title: 'Weekly Journal #14',                    excerpt: 'Oral exams finished. First real week of summer break. Coffee, rain, Honkai.',                              href: '#', date: 'Mar 27, 2026', category: 'Journal', tags: ['Life'],              image: null, idx: 5 },
  { title: 'Why I Switched from Next.js to Astro',  excerpt: 'Hydration budget, island architecture, the joy of zero JS by default.',                                   href: '#', date: 'Mar 20, 2026', category: 'Dev',     tags: ['Astro', 'Next.js'],  image: null, idx: 6 },
  { title: 'Rewatching Steins;Gate in 2026',        excerpt: 'Still hits. Okabe is peak fiction. The VN-to-anime choices hold up better than I remembered.',            href: '#', date: 'Mar 13, 2026', category: 'Anime',   tags: ['ACGN', 'Classic'],   image: null, idx: 7 },
];

const display = items.length ? items : demo;

const catStyle: Record<string, { accent: string; bg: string; border: string }> = {
  Anime:   { accent: '#e07800', bg: 'rgba(255,149,0,0.08)',   border: 'rgba(255,149,0,0.22)'   },
  Design:  { accent: '#2ba8a0', bg: 'rgba(57,197,187,0.08)',  border: 'rgba(57,197,187,0.22)'  },
  Dev:     { accent: '#475569', bg: 'rgba(100,116,139,0.08)', border: 'rgba(100,116,139,0.2)'  },
  Journal: { accent: '#7c3aed', bg: 'rgba(139,92,246,0.08)',  border: 'rgba(139,92,246,0.2)'   },
};
const fallback = { accent: '#475569', bg: 'rgba(100,116,139,0.08)', border: 'rgba(100,116,139,0.2)' };
---

<section style="font-family:'Plus Jakarta Sans',sans-serif;" aria-label="Recent posts">

  <!-- Centered kfdzcoffee-style section divider -->
  <div class="flex items-center gap-4 mb-6">
    <div class="flex-1 h-px" style="background:linear-gradient(to right,transparent,rgba(57,197,187,0.4))"></div>
    <span class="text-[10px] font-black tracking-[0.22em] uppercase" style="color:#39c5bb">Recent Posts</span>
    <div class="flex-1 h-px" style="background:linear-gradient(to left,transparent,rgba(57,197,187,0.4))"></div>
  </div>

  <!-- Post list -->
  <div class="space-y-2.5">
    {display.map((post) => {
      const cs = catStyle[post.category] ?? fallback;
      return (
        <a
          href={post.href}
          class="group flex items-stretch bg-white rounded-2xl border overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_6px_24px_rgba(57,197,187,0.10)]"
          style="border-color:rgba(226,232,240,0.9);"
        >
          <!-- Left accent bar -->
          <div
            class="w-[3px] shrink-0 transition-all duration-300 group-hover:w-1"
            style={`background:${cs.accent};`}
          ></div>

          <!-- Body -->
          <div class="flex-1 flex items-center gap-4 px-5 py-4 min-w-0">

            <div class="flex-1 min-w-0">
              <!-- Meta row -->
              <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                <span
                  class="px-2.5 py-0.5 rounded-full text-[9px] font-black uppercase tracking-wider border"
                  style={`background:${cs.bg};color:${cs.accent};border-color:${cs.border};`}
                >
                  {post.category}
                </span>
                {post.tags.map(tag => (
                  <span class="text-[10px] font-mono" style="color:#cbd5e1">#{tag}</span>
                ))}
                <span class="text-[10px] font-mono ml-auto" style="color:#cbd5e1">{post.date}</span>
              </div>

              <!-- Title -->
              <h3
                class="text-[14px] font-black leading-snug tracking-tight line-clamp-1 transition-colors duration-200 group-hover:text-[#39c5bb]"
                style="color:#0f172a;"
              >
                {post.title}
              </h3>

              <!-- Excerpt -->
              {post.excerpt && (
                <p class="text-[12px] font-medium leading-relaxed mt-1 line-clamp-2" style="color:#94a3b8;">
                  {post.excerpt}
                </p>
              )}
            </div>

            <!-- Thumbnail -->
            <div
              class="shrink-0 w-[76px] h-[76px] rounded-xl overflow-hidden"
              style={`background:${cs.bg};`}
            >
              {post.image ? (
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-[11px] font-black" style={`color:${cs.accent};opacity:0.45;`}>
                    {post.category.slice(0,2).toUpperCase()}
                  </span>
                </div>
              )}
            </div>
          </div>
        </a>
      );
    })}
  </div>

  <!-- View all -->
  <div class="mt-5 flex justify-center">
    <a
      href="/posts"
      class="inline-flex items-center gap-1.5 text-[12px] font-bold transition-colors duration-200 text-slate-400 hover:text-[#39c5bb]"
    >
      View all posts
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

</section>