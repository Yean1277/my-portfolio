---
/**
 * RecentPosts.astro
 * White card list — left accent bar, category badge + #tags + date meta row,
 * title, excerpt, and a tinted square code-badge on the right (e.g. "AN", "DE", "JO").
 *
 * Matches the May 2026 prototype: no centered "Recent Posts" divider — the list
 * starts straight away. Cards are larger, more padded, and scan top-to-bottom.
 */

interface Post {
  slug: string;
  data: {
    title: string;
    description?: string;
    date: Date | string;
    category?: string;
    tags?: string[];
    heroImage?: string;
  };
}

interface Props {
  posts: Post[];
  maxItems?: number;
}

const { posts, maxItems = 8 } = Astro.props;

const fmt = (d: Date | string) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const items = posts.slice(0, maxItems).map((p, i) => ({
  title:    p.data.title,
  excerpt:  p.data.description ?? '',
  href:     `/posts/${p.slug}`,
  date:     fmt(p.data.date),
  category: p.data.category ?? 'Post',
  tags:     (p.data.tags ?? []).slice(0, 2),
  image:    p.data.heroImage ?? null,
  idx:      i,
}));

const demo = [
  { title: 'My Top 5 Anime This Season',           excerpt: "A personal tracking system for anime I'm loving right now—and why I built this portfolio partly to show them off.", href: '#', date: 'Jul 15, 2024', category: 'Anime',   tags: ['ACGN', 'Review'],    image: null, idx: 0 },
  { title: 'Designing Card-Based UI Systems',       excerpt: 'Gradient rings, shimmer overlays, and composable components in Astro.',                                            href: '#', date: 'Apr 24, 2026', category: 'Design',  tags: ['UI', 'Astro'],       image: null, idx: 1 },
  { title: 'Building a Music Player in Astro',      excerpt: 'No framework JS — just Astro islands and a spinning vinyl record made from plain SVG.',                            href: '#', date: 'Apr 17, 2026', category: 'Dev',     tags: ['Astro', 'Audio'],    image: null, idx: 2 },
  { title: 'Honkai: Star Rail Lore Deep Dive',      excerpt: 'Catching up before the next arc. Spoilers for Penacony. Why is Firefly so good.',                                  href: '#', date: 'Apr 10, 2026', category: 'Anime',   tags: ['ACGN', 'Honkai'],    image: null, idx: 3 },
  { title: 'Three.js Particle Systems on a Budget', excerpt: '60fps star-field effects without a beefy GPU — instanced mesh and frustum culling.',                               href: '#', date: 'Apr 3, 2026',  category: 'Dev',     tags: ['Three.js', 'WebGL'], image: null, idx: 4 },
  { title: 'Weekly Journal #14',                    excerpt: 'Oral exams finished. First real week of summer break. Coffee, rain, Honkai.',                                      href: '#', date: 'Mar 27, 2026', category: 'Journal', tags: ['Life'],              image: null, idx: 5 },
  { title: 'Why I Switched from Next.js to Astro',  excerpt: 'Hydration budget, island architecture, the joy of zero JS by default.',                                            href: '#', date: 'Mar 20, 2026', category: 'Dev',     tags: ['Astro', 'Next.js'],  image: null, idx: 6 },
  { title: 'Rewatching Steins;Gate in 2026',        excerpt: 'Still hits. Okabe is peak fiction. The VN-to-anime choices hold up better than I remembered.',                     href: '#', date: 'Mar 13, 2026', category: 'Anime',   tags: ['ACGN', 'Classic'],   image: null, idx: 7 },
];

const display = items.length ? items : demo;

// Category style map — accent bar, category-pill bg/text, right-side code-box bg/text
const catStyle: Record<string, {
  accent: string;
  pillBg: string; pillText: string; pillBorder: string;
  boxBg:  string; boxText:  string;
  code:   string;
}> = {
  Anime:   { accent: '#F07535', pillBg: 'rgba(240,117,53,0.10)',  pillText: '#D4612A', pillBorder: 'rgba(240,117,53,0.30)', boxBg: 'rgba(240,117,53,0.08)',  boxText: '#D4612A', code: 'AN' },
  Design:  { accent: '#39c5bb', pillBg: 'rgba(57,197,187,0.10)',  pillText: '#2ba8a0', pillBorder: 'rgba(57,197,187,0.32)', boxBg: 'rgba(57,197,187,0.08)',  boxText: '#2ba8a0', code: 'DE' },
  Dev:     { accent: '#475569', pillBg: 'rgba(71,85,105,0.10)',   pillText: '#334155', pillBorder: 'rgba(71,85,105,0.25)',  boxBg: 'rgba(71,85,105,0.06)',   boxText: '#475569', code: 'DV' },
  Journal: { accent: '#F5B3C8', pillBg: 'rgba(245,179,200,0.12)', pillText: '#E0899F', pillBorder: 'rgba(245,179,200,0.35)', boxBg: 'rgba(245,179,200,0.10)', boxText: '#E0899F', code: 'JO' },
};
const fallback = { accent: '#475569', pillBg: 'rgba(71,85,105,0.10)', pillText: '#334155', pillBorder: 'rgba(71,85,105,0.25)', boxBg: 'rgba(71,85,105,0.06)', boxText: '#475569', code: 'PO' };
---

<section style="font-family:'Plus Jakarta Sans',sans-serif;" aria-label="Recent posts">

  <!-- Post list — no top divider, content starts immediately -->
  <div class="space-y-3">
    {display.map((post) => {
      const cs = catStyle[post.category] ?? fallback;
      return (
        <a
          href={post.href}
          class="group flex items-stretch bg-white rounded-2xl border border-slate-100 overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_6px_24px_rgba(15,23,42,0.06)]"
        >
          <!-- Left accent bar -->
          <div
            class="w-[4px] shrink-0 transition-all duration-300 group-hover:w-1.5"
            style={`background:${cs.accent};`}
          ></div>

          <!-- Body -->
          <div class="flex-1 flex items-center gap-4 px-5 py-4 min-w-0">

            <div class="flex-1 min-w-0">

              <!-- Date -->
              <div class="flex items-center mb-1.5">
                <span class="text-[10px] font-mono text-slate-300 tabular-nums">
                  {post.date}
                </span>
              </div>

              <!-- Title -->
              <h3
                class="text-[14px] font-black leading-snug tracking-tight line-clamp-1 transition-colors duration-200 group-hover:text-[#39c5bb]"
                style="color:#0f172a;"
              >
                {post.title}
              </h3>

              <!-- Excerpt -->
              {post.excerpt && (
                <p class="text-[12px] font-medium leading-relaxed mt-1 line-clamp-2" style="color:#94a3b8;">
                  {post.excerpt}
                </p>
              )}
            </div>

          </div>
        </a>
      );
    })}
  </div>

  <!-- View all -->
  <div class="mt-7 flex justify-center">
    <a
      href="/posts"
      class="inline-flex items-center gap-1.5 text-[12px] font-bold transition-colors duration-200 text-slate-400 hover:text-[#39c5bb]"
    >
      View all posts
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</section>