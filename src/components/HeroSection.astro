---
/**
 * HeroSection.astro
 * Full-viewport hero — lives OUTSIDE max-w-[1100px], bleeds edge-to-edge.
 * Place it as the very first child of <body>, before <main>.
 *
 * Props:
 *   title       — large display name shown center-screen
 *   tagline     — subtitle below title (bilingual, motto, etc.)
 *   greeting    — small line above title (e.g. "👋 Hey, welcome!")
 *   wallpaper   — path/URL to the hero background image
 *   wallpapers  — optional array of {src, alt} for slideshow mode
 *   liveLabel   — optional top-left badge text (default "LIVE")
 *   primaryCta  — { label, href } for the main button (default "Browse Work" → /projects)
 *   secondaryCta— { label, href, badge } for the second button (default "Anime Labs" w/ "New" badge)
 */

interface WallpaperItem {
  src: string;
  alt?: string;
}

interface CtaItem {
  label: string;
  href: string;
  badge?: string;
}

interface Props {
  title: string;
  tagline?: string;
  greeting?: string;
  wallpaper?: string;
  wallpapers?: WallpaperItem[];
  liveLabel?: string;
  primaryCta?: CtaItem;
  secondaryCta?: CtaItem;
}

const {
  title,
  tagline,
  greeting,
  wallpaper = 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80',
  wallpapers,
  liveLabel = 'LIVE',
  primaryCta   = { label: 'Browse Work', href: '/projects' },
  secondaryCta = { label: 'Anime Labs',  href: '/anime', badge: 'New' },
} = Astro.props;

// If wallpapers array provided, use it; else wrap single wallpaper
const slides: WallpaperItem[] = wallpapers?.length
  ? wallpapers
  : [{ src: wallpaper, alt: title }];

const isVideo = (src: string) => /\.(mp4|webm|ogg)(\?.*)?$/i.test(src);
---

<section
  id="hero-section"
  class="relative w-full overflow-hidden"
  style="min-height: 100vh;"
  aria-label="Hero section"
>
  <!-- ── WALLPAPER SLIDES ───────────────────────────────────────────── -->
  <div id="hero-slides" class="absolute inset-0">
    {slides.map((slide, i) => (
      isVideo(slide.src) ? (
        <video
          src={slide.src}
          class:list={[
            'absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-[600ms] ease-site',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
          data-slide={i}
          autoplay
          muted
          loop
          playsinline
        />
      ) : (
        <img
          src={slide.src}
          alt={slide.alt ?? title}
          class:list={[
            'absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-[600ms] ease-site',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
          data-slide={i}
          fetchpriority={i === 0 ? 'high' : 'low'}
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      )
    ))}
  </div>

  <!-- ── GRADIENT SCRIM ────────────────────────────────────────────── -->
  <!-- Transparent at top so art breathes; darkens toward bottom for text legibility -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to bottom, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.18) 35%, rgba(0,0,0,0.55) 70%, rgba(0,0,0,0.85) 100%);"
    aria-hidden="true"
  ></div>

  <!-- ── SLOT: Navigation floats here (injected by parent) ────────── -->
  <slot name="nav" />

  <!-- ── CENTER TEXT BLOCK ─────────────────────────────────────────── -->
  <div
    class="absolute inset-x-0 z-10 flex flex-col items-center text-center px-6"
    style="bottom: 24%;"
  >
    <!-- Greeting line -->
    {greeting && (
      <p class="text-white/85 text-[13px] font-medium mb-3 flex items-center gap-2 tracking-wide drop-shadow">
        {greeting}
      </p>
    )}

    <!-- Main title -->
    <h1
      class="text-white font-black leading-[1.05] tracking-tight mb-3"
      style="font-size: clamp(2.6rem, 6.5vw, 4.5rem); text-shadow: 0 2px 28px rgba(0,0,0,0.45);"
    >
      {title}
    </h1>

    <!-- Tagline -->
    {tagline && (
      <p
        class="text-white/75 font-medium tracking-wide mb-7"
        style="font-size: clamp(0.85rem, 1.6vw, 1rem);"
      >
        {tagline}
      </p>
    )}

    <!-- ── CTA ROW ──────────────────────────────────────────────────── -->
    <div class="flex items-center gap-3 flex-wrap justify-center">
      <!-- Primary: Browse Work (teal solid) -->
      <a
        href={primaryCta.href}
        class="inline-flex items-center justify-center bg-[#39c5bb] hover:bg-[#2ba8a0] text-white font-medium text-[13px] px-7 py-3 rounded-full shadow-[0_4px_24px_rgba(57,197,187,0.25)] hover:shadow-[0_6px_28px_rgba(57,197,187,0.4)] hover:-translate-y-0.5 transition-all duration-150 ease-site"
      >
        {primaryCta.label}
      </a>

      <!-- Secondary: Anime Labs (dark glass with badge) -->
      <a
        href={secondaryCta.href}
        class="inline-flex items-center gap-2 bg-[#24231f]/70 backdrop-blur-md text-white font-medium text-[13px] px-7 py-3 rounded-full border border-white/15 hover:bg-[#24231f]/85 hover:-translate-y-0.5 transition-all duration-150 ease-site"
      >
        {secondaryCta.label}
        {secondaryCta.badge && (
          <span class="text-[8px] font-black uppercase tracking-wide px-2 py-0.5 rounded-full bg-kato text-white">
            {secondaryCta.badge}
          </span>
        )}
      </a>
    </div>
  </div>

  <!-- ── SLOT: HeroTicker lives here ──────────────────────────────── -->
  <slot name="ticker" />

  <!-- ── BOTTOM-CENTER SLIDE NAV (prev / dots / next) ─────────────── -->
  {slides.length > 0 && (
    <div
      id="hero-dots"
      class="absolute z-20 flex items-center gap-2 left-1/2 -translate-x-1/2 px-3 py-2 rounded-full bg-[#24231f]/45 backdrop-blur-md border border-white/10"
      style="bottom: 80px;"
      aria-label="Slide indicators"
    >
      <!-- Prev -->
      <button
        type="button"
        data-slide-prev
        aria-label="Previous slide"
        class="w-7 h-7 rounded-full flex items-center justify-center text-white/70 hover:text-white hover:bg-white/10 transition-all"
      >
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M7 1L3 5L7 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Dots -->
      <div class="flex items-center gap-1.5 px-1">
        {slides.map((_, i) => (
          <button
            type="button"
            class:list={[
              'rounded-full transition-all duration-300',
              i === 0
                ? 'w-5 h-[7px] bg-white'
                : 'w-[7px] h-[7px] bg-white/40 hover:bg-white/60',
            ]}
            data-dot={i}
            aria-label={`Go to slide ${i + 1}`}
          />
        ))}
      </div>

      <!-- Next -->
      <button
        type="button"
        data-slide-next
        aria-label="Next slide"
        class="w-7 h-7 rounded-full flex items-center justify-center text-white/70 hover:text-white hover:bg-white/10 transition-all"
      >
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M3 1L7 5L3 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  )}

  <!-- ── SCROLL HINT ───────────────────────────────────────────────── -->
  <div
    class="absolute bottom-3 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1.5 opacity-50 hover:opacity-80 transition-opacity"
    aria-hidden="true"
    id="scroll-hint"
  >
    <div class="w-px h-6 bg-white/60" style="animation: scrollPulse 2s ease-in-out infinite;"></div>
  </div>
</section>

<style>
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50%       { opacity: 0.9; transform: scaleY(1.15); }
  }
</style>

<script>
  const section    = document.getElementById('hero-section')!;
  const slidesEl   = section.querySelectorAll<HTMLImageElement>('[data-slide]');
  const dotsEl     = section.querySelectorAll<HTMLButtonElement>('[data-dot]');
  const prevBtn    = section.querySelector<HTMLButtonElement>('[data-slide-prev]');
  const nextBtn    = section.querySelector<HTMLButtonElement>('[data-slide-next]');
  const dismissBtn = document.getElementById('hero-dismiss');
  const scrollHint = document.getElementById('scroll-hint');

  let current = 0;
  const total = slidesEl.length;

  // ── Slide switching ────────────────────────────────────────────────
  function goTo(idx: number) {
    if (total <= 1) return;
    const prev = current;
    current = ((idx % total) + total) % total;
    if (prev === current) return;

    slidesEl[prev].style.opacity = '0';
    slidesEl[current].style.opacity = '1';

    dotsEl.forEach((d, i) => {
      const isActive = i === current;
      d.classList.toggle('w-5',         isActive);
      d.classList.toggle('bg-white',    isActive);
      d.classList.toggle('w-[7px]',     !isActive);
      d.classList.toggle('h-[7px]',     true);
      d.classList.toggle('bg-white/40', !isActive);
    });
  }

  // Dot clicks
  dotsEl.forEach((btn, i) => btn.addEventListener('click', () => goTo(i)));

  // Prev / Next
  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));

  // Auto-advance on first visit only
  if (total > 1 && !sessionStorage.getItem('hero-visited')) {
    sessionStorage.setItem('hero-visited', '1');
    setInterval(() => goTo(current + 1), 6000);
  }

  // ── Dismiss button: simple fade-hide of itself ─────────────────────
  dismissBtn?.addEventListener('click', () => {
    dismissBtn.style.opacity = '0';
    dismissBtn.style.pointerEvents = 'none';
    setTimeout(() => { dismissBtn.style.display = 'none'; }, 200);
  });

  // ── Fade scroll hint on scroll ─────────────────────────────────────
  window.addEventListener('scroll', () => {
    if (scrollHint) {
      scrollHint.style.opacity = window.scrollY > 40 ? '0' : '0.5';
    }
  }, { passive: true });
</script>
