---
/**
 * HeroSection.astro
 * Full-viewport hero — lives OUTSIDE max-w-[1100px], bleeds edge-to-edge.
 * Place it as the very first child of <body>, before <main>.
 *
 * Props:
 *   title       — large display name shown center-screen
 *   tagline     — subtitle below title (bilingual, motto, etc.)
 *   greeting    — small line above title (e.g. "👋 Hey, welcome!")
 *   wallpaper   — path/URL to the hero background image
 *   wallpapers  — optional array of {src, alt} for slideshow mode
 *   badge       — optional top-right corner badge text (e.g. "HRO-001")
 *   liveLabel   — optional top-left badge text (default "LIVE")
 */

interface WallpaperItem {
  src: string;
  alt?: string;
}

interface Props {
  title: string;
  tagline?: string;
  greeting?: string;
  wallpaper?: string;
  wallpapers?: WallpaperItem[];
  badge?: string;
  liveLabel?: string;
}

const {
  title,
  tagline,
  greeting,
  wallpaper = 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80',
  wallpapers,
  badge = 'HRO-001',
  liveLabel = 'LIVE',
} = Astro.props;

// If wallpapers array provided, use it; else wrap single wallpaper
const slides: WallpaperItem[] = wallpapers?.length
  ? wallpapers
  : [{ src: wallpaper, alt: title }];
---

<section
  id="hero-section"
  class="relative w-full overflow-hidden"
  style="min-height: 100vh;"
  aria-label="Hero section"
>
  <!-- ── WALLPAPER SLIDES ───────────────────────────────────────────── -->
  <div id="hero-slides" class="absolute inset-0">
    {slides.map((slide, i) => (
      <img
        src={slide.src}
        alt={slide.alt ?? title}
        class:list={[
          'absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-700',
          i === 0 ? 'opacity-100' : 'opacity-0',
        ]}
        data-slide={i}
        fetchpriority={i === 0 ? 'high' : 'low'}
        loading={i === 0 ? 'eager' : 'lazy'}
      />
    ))}
  </div>

  <!-- ── GRADIENT SCRIM ────────────────────────────────────────────── -->
  <!-- Transparent at top so art breathes; darkens toward bottom for text legibility -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to bottom, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.18) 35%, rgba(0,0,0,0.55) 70%, rgba(0,0,0,0.78) 100%);"
    aria-hidden="true"
  ></div>

  <!-- ── CORNER BADGES ─────────────────────────────────────────────── -->
  <!-- Top-left: LIVE (teal) -->
  <div class="absolute top-20 left-6 z-20 pointer-events-none" aria-hidden="true">
    <div class="flex items-center gap-1.5 px-2.5 py-1 bg-[#39c5bb]/80 backdrop-blur-sm rounded-lg border border-white/20">
      <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
      <span class="text-[9px] font-black text-white italic tracking-wide">{liveLabel}</span>
    </div>
  </div>

  <!-- Top-right: serial number (orange) -->
  <div class="absolute top-20 right-6 z-20 pointer-events-none" aria-hidden="true">
    <div class="px-2.5 py-1 bg-orange-500/80 backdrop-blur-sm rounded-lg border border-white/20">
      <span class="text-[9px] font-mono text-white font-bold">{badge}</span>
    </div>
  </div>

  <!-- ── SLOT: Navigation floats here (injected by parent) ────────── -->
  <slot name="nav" />

  <!-- ── CENTER TEXT BLOCK ─────────────────────────────────────────── -->
  <div
    class="absolute inset-x-0 z-10 flex flex-col items-center text-center px-6"
    style="bottom: 22%;"
  >
    <!-- Greeting line -->
    {greeting && (
      <p class="text-white/80 text-[13px] font-medium mb-3 flex items-center gap-2 tracking-wide">
        {greeting}
      </p>
    )}

    <!-- Main title — large, bold, mixed weight -->
    <h1
      class="text-white font-black leading-[1.08] tracking-tight mb-3"
      style="font-size: clamp(2.4rem, 6vw, 4rem); font-family: 'Plus Jakarta Sans', sans-serif; text-shadow: 0 2px 24px rgba(0,0,0,0.35);"
    >
      {title}
    </h1>

    <!-- Tagline -->
    {tagline && (
      <p
        class="text-white/70 font-medium tracking-wide"
        style="font-size: clamp(0.8rem, 1.6vw, 0.95rem);"
      >
        {tagline}
      </p>
    )}
  </div>

  <!-- ── SLOT: HeroTicker lives here ──────────────────────────────── -->
  <slot name="ticker" />

  <!-- ── SLIDE DOTS (bottom-left) ─────────────────────────────────── -->
  {slides.length > 0 && (
    <div
      id="hero-dots"
      class="absolute bottom-5 left-6 z-20 flex items-center gap-2"
      aria-label="Slide indicators"
    >
      <!-- Home icon dot -->
      <button
        class="w-7 h-7 rounded-full flex items-center justify-center bg-white/20 hover:bg-white/30 transition-colors backdrop-blur-sm"
        aria-label="Go to first slide"
        data-dot-home
      >
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M1 5.5L6 1.5L11 5.5V10.5H8V7.5H4V10.5H1V5.5Z" fill="white" opacity="0.9"/>
        </svg>
      </button>

      {slides.map((_, i) => (
        <button
          class:list={[
            'rounded-full transition-all duration-300',
            i === 0
              ? 'w-5 h-[7px] bg-white'
              : 'w-[7px] h-[7px] bg-white/40 hover:bg-white/60',
          ]}
          data-dot={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>
  )}

  <!-- ── SCROLL HINT ───────────────────────────────────────────────── -->
  <div
    class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1.5 opacity-50 hover:opacity-80 transition-opacity"
    aria-hidden="true"
    id="scroll-hint"
  >
    <div class="w-px h-8 bg-white/60" style="animation: scrollPulse 2s ease-in-out infinite;"></div>
    <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
      <path d="M1 1L5 5L9 1" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50%       { opacity: 0.9; transform: scaleY(1.15); }
  }
</style>

<script>
  const section   = document.getElementById('hero-section')!;
  const slidesEl  = section.querySelectorAll<HTMLImageElement>('[data-slide]');
  const dotsEl    = section.querySelectorAll<HTMLButtonElement>('[data-dot]');
  const homeBtn   = section.querySelector<HTMLButtonElement>('[data-dot-home]');
  const scrollHint = document.getElementById('scroll-hint');

  let current = 0;
  const total = slidesEl.length;

  // ── Slide switching ────────────────────────────────────────────────
  function goTo(idx: number) {
    if (total <= 1) return;
    const prev = current;
    current = ((idx % total) + total) % total;
    if (prev === current) return;

    slidesEl[prev].style.opacity = '0';
    slidesEl[current].style.opacity = '1';

    dotsEl.forEach((d, i) => {
      const isActive = i === current;
      d.classList.toggle('w-5',    isActive);
      d.classList.toggle('h-[7px]', isActive);
      d.classList.toggle('bg-white', isActive);
      d.classList.toggle('w-[7px]', !isActive);
      d.classList.toggle('h-[7px]', true);
      d.classList.toggle('bg-white/40', !isActive);
    });
  }

  // Dot clicks
  dotsEl.forEach((btn, i) => btn.addEventListener('click', () => goTo(i)));
  homeBtn?.addEventListener('click', () => goTo(0));

  // Auto-advance if multiple slides
  if (total > 1) {
    setInterval(() => goTo(current + 1), 5000);
  }

  // ── Fade scroll hint on scroll ─────────────────────────────────────
  window.addEventListener('scroll', () => {
    if (scrollHint) {
      scrollHint.style.opacity = window.scrollY > 40 ? '0' : '0.5';
    }
  }, { passive: true });
</script>