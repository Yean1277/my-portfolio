---
const { title, date, category, wordCount, description, tags, image, isEncrypted } = Astro.props;
---
<!-- DEPRECATED: This component uses the old pastel design system (wisteria/celadon/sakura colors).
     The Fidelity design system (teal #39C5BB) is now the canonical design.
     Currently replaced by inline post rendering in src/pages/index.astro.
     When refactoring, use the Fidelity color palette: --color-primary: #39C5BB, --color-bg-primary-soft: #E8F8F7 -->
<article class={
  `post-card group cursor-pointer overflow-hidden rounded-[28px] border border-[#f0e3ed] bg-white shadow-soft ${isEncrypted ? 'opacity-95' : ''}`
}>
  <div class="grid gap-6 p-6 sm:grid-cols-[1.4fr_0.8fr] items-center">
    <div>
      <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.25em] text-[#8b6b90]">
        <span class="rounded-full bg-sakura-soft px-3 py-1">{category}</span>
        {isEncrypted ? <span class="rounded-full bg-rose-fog px-3 py-1 text-[#9f6c7e]">已加密</span> : null}
      </div>
      <h3 class="mt-4 text-2xl font-semibold text-[#3f3240] transition-colors group-hover:text-wisteria">{title}</h3>
      <div class="mt-3 flex flex-wrap gap-3 text-sm text-[#7b6d66]">
        <span class="inline-flex items-center gap-2">📅 {date}</span>
        <span class="inline-flex items-center gap-2">📝 {wordCount} 字</span>
      </div>
      <p class="mt-4 text-sm leading-7 text-[#6f5f60]">{description}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full bg-mist-violet px-3 py-1 text-xs font-semibold text-[#6e5d6e]">#{tag}</span>
        ))}
      </div>
    </div>

    {image ? (
      <div class="overflow-hidden rounded-[24px] border border-[#f0e0e8] bg-[#faf2f7] shadow-card">
        <img alt="Post Preview" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" src={image} />
      </div>
    ) : (
      <div class="flex h-44 items-center justify-center rounded-[24px] bg-mist-violet-soft text-[#5f4b55]">稍后更新</div>
    )}
  </div>
</article>
