---
interface Props {
  posts: any[];
}

const { posts } = Astro.props;

const accentColors = ['#39c5bb', '#F07535', '#F5B3C8', '#475569'];

const displayPosts = posts.length > 0
  ? posts.slice(0, 4).map((p, i) => ({
      title:   p.data.title,
      excerpt: p.data.description ?? p.data.excerpt ?? '',
      href:    `/posts/${p.slug}`,
      date:    p.data.date ? new Date(p.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '',
      idx: i,
    }))
  : [
      { title: 'Yean Ter Portfolio',       excerpt: 'A personal portfolio built with Astro, Tailwind, and a lot of attention to detail.',     href: '/projects', date: 'Mar 2026', idx: 0 },
      { title: 'Anime Collection Viewer',  excerpt: 'Personal anime tracker with a flip-card grid and seasonal stats.',                        href: '/anime',    date: 'Apr 2026', idx: 1 },
      { title: 'Floating Music Player',    excerpt: 'Viewport-anchored music island with spinning vinyl and a playlist drawer.',               href: '/projects', date: 'May 2026', idx: 2 },
      { title: 'Cinematic Hero System',    excerpt: 'Full-bleed wallpaper slideshow with auto-fade and overlay navigation.',                   href: '/projects', date: 'May 2026', idx: 3 },
    ];
---

<section style="font-family:'Plus Jakarta Sans',sans-serif;" aria-label="Projects">

  <!-- Section header -->
  <div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-2">
      <svg class="w-2 h-2 text-[#39c5bb]" viewBox="0 0 8 8" fill="currentColor" aria-hidden="true">
        <circle cx="4" cy="4" r="4"/>
      </svg>
      <span class="text-[9px] text-[#39c5bb] font-black tracking-[0.2em] uppercase">Projects</span>
    </div>
    <a
      href="/projects"
      class="text-[11px] font-bold text-slate-400 hover:text-[#39c5bb] transition-colors flex items-center gap-1"
    >
      View all
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
        <path d="M2 5H8M5 2L8 5L5 8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <!-- Card list -->
  <div class="space-y-3">
    {displayPosts.map((post) => {
      const accent = accentColors[post.idx % accentColors.length];
      return (
        <a
          href={post.href}
          class="group flex items-stretch bg-white rounded-2xl border border-slate-100 overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_6px_24px_rgba(15,23,42,0.06)]"
        >
          <!-- Left accent bar -->
          <div
            class="w-[4px] shrink-0 transition-all duration-300 group-hover:w-1.5"
            style={`background:${accent};`}
          ></div>

          <div class="flex-1 px-5 py-4 min-w-0">

            <!-- Date -->
            <p class="text-[10px] font-mono text-slate-300 tabular-nums mb-1.5">{post.date}</p>

            <!-- Title -->
            <h3
              class="text-[14px] font-black leading-snug tracking-tight line-clamp-1 transition-colors duration-200 group-hover:text-[#39c5bb]"
              style="color:#0f172a;"
            >
              {post.title}
            </h3>

            <!-- Excerpt -->
            {post.excerpt && (
              <p class="text-[12px] font-medium leading-relaxed mt-1 line-clamp-2" style="color:#94a3b8;">
                {post.excerpt}
              </p>
            )}
          </div>
        </a>
      );
    })}
  </div>

</section>
