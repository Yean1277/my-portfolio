---
/**
 * ProjectCollections.astro
 * 2-column project card grid with alternating teal/orange gradient rings.
 * Falls back to static demo cards when posts array is empty.
 *
 * Props:
 *   posts — from getCollection('posts') in index.astro
 */

interface Props {
  posts: any[];
}

const { posts } = Astro.props;

// Alternating accent palette (i % 2)
const cardAccents = [
  {
    ring:    'from-[#39c5bb]/50 to-orange-300/30',
    badge:   'bg-[#39c5bb]/80',
    cat:     'bg-[#39c5bb]/10 text-[#2ba8a0] border-[#39c5bb]/30',
    accent:  '#39c5bb',
  },
  {
    ring:    'from-orange-400/50 to-[#39c5bb]/30',
    badge:   'bg-orange-500/80',
    cat:     'bg-orange-50 text-orange-500 border-orange-200',
    accent:  '#FF9500',
  },
];

const toSerial = (i: number) => `PRJ-${String(i + 1).padStart(3, '0')}`;

// Build display items — real posts or static fallback
const displayPosts = posts.length > 0
  ? posts.slice(0, 4).map((p, i) => ({
      title:    p.data.title,
      excerpt:  p.data.description ?? p.data.excerpt ?? '',
      href:     `/posts/${p.slug}`,
      category: p.data.category ?? 'Project',
      image:    p.data.heroImage ?? p.data.image ?? null,
      idx: i,
    }))
  : [
      { title: 'Lumina Dashboard',       excerpt: 'A data-rich analytics UI built for clarity and speed.',             href: '/projects', category: 'Case Study',   image: null, idx: 0 },
      { title: 'Cyber-Neko UI Kit',       excerpt: 'Anime-inspired component library for React projects.',              href: '/projects', category: 'Experimental', image: null, idx: 1 },
      { title: 'Astro Portfolio System',  excerpt: 'The very site you\'re on — Astro + Three.js + Tailwind.',           href: '/projects', category: 'Open Source',  image: null, idx: 2 },
      { title: 'Anime Collection Viewer', excerpt: 'Personal anime tracker with seasonal charts and stats.',             href: '/anime',    category: 'Personal',     image: null, idx: 3 },
    ];
---

<section style="font-family:'Plus Jakarta Sans',sans-serif;" aria-label="Projects">

  <!-- Section header -->
  <div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-2">
      <svg class="w-2 h-2 text-[#39c5bb]" viewBox="0 0 8 8" fill="currentColor" aria-hidden="true">
        <circle cx="4" cy="4" r="4"/>
      </svg>
      <span class="text-[9px] text-[#39c5bb] font-black tracking-[0.2em] uppercase">Latest projects</span>
    </div>
    <a
      href="/projects"
      class="text-[11px] font-bold text-slate-400 hover:text-[#39c5bb] transition-colors flex items-center gap-1"
    >
      View all
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
        <path d="M2 5H8M5 2L8 5L5 8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <!-- 2-column card grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    {displayPosts.map((post) => {
      const a = cardAccents[post.idx % 2];
      return (
        <div class="relative group hover:-translate-y-1.5 transition-transform duration-300">
          <!-- Gradient ring -->
          <div class:list={['absolute -inset-[2px] rounded-[34px] bg-gradient-to-br -z-10', a.ring]}></div>

          <article class="bg-white rounded-[32px] overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] h-full flex flex-col">

            <!-- Image / placeholder -->
            <div class="relative overflow-hidden bg-[#f8fafc]" style="height:160px;">
              {post.image ? (
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover object-center group-hover:scale-110 transition-transform duration-700"
                  loading="lazy"
                />
              ) : (
                /* Decorative placeholder with brand gradient */
                <div class="w-full h-full flex items-center justify-center" style={`background: linear-gradient(135deg, ${a.accent}15, ${a.accent}05);`}>
                  <div class="flex flex-col items-center gap-2 opacity-30">
                    <div class="w-8 h-8 rounded-xl border-2" style={`border-color: ${a.accent};`}></div>
                    <div class="w-16 h-1.5 rounded-full" style={`background: ${a.accent};`}></div>
                    <div class="w-10 h-1.5 rounded-full" style={`background: ${a.accent}80;`}></div>
                  </div>
                </div>
              )}

              <!-- Top-left: LIVE badge -->
              <div class="absolute top-3 left-3">
                <div class="px-2 py-1 bg-[#39c5bb]/80 backdrop-blur-sm rounded-lg border border-white/20">
                  <span class="text-[8px] font-black text-white italic tracking-wide">OPEN</span>
                </div>
              </div>

              <!-- Top-right: serial badge -->
              <div class="absolute top-3 right-3">
                <div class:list={['px-2 py-1 backdrop-blur-sm rounded-lg border border-white/20', a.badge]}>
                  <span class="text-[8px] font-mono text-white font-bold">{toSerial(post.idx)}</span>
                </div>
              </div>
            </div>

            <!-- Body -->
            <div class="p-5 flex flex-col flex-1">

              <!-- Category tag -->
              <div class="mb-3">
                <span class:list={['px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border', a.cat]}>
                  {post.category}
                </span>
              </div>

              <!-- Title -->
              <h4 class="text-slate-900 text-base font-black tracking-tight leading-snug mb-2">
                {post.title}
              </h4>

              <!-- Excerpt -->
              {post.excerpt && (
                <p class="text-slate-500 text-[12px] font-medium leading-relaxed flex-1 mb-4 line-clamp-2">
                  {post.excerpt}
                </p>
              )}

              <!-- CTA -->
              <a
                href={post.href}
                class="inline-flex items-center gap-1.5 text-[11px] font-bold mt-auto transition-colors duration-200"
                style={`color: ${a.accent};`}
              >
                View project
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                  <path d="M2 5H8M5 2L8 5L5 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

          </article>

          <!-- Shimmer overlay -->
          <div class:list={[
            'pointer-events-none absolute inset-0 rounded-[32px]',
            'bg-gradient-to-br from-white/0 via-orange-100/20 to-[#39c5bb]/10',
            'opacity-0 group-hover:opacity-100 transition-opacity duration-500',
          ]} aria-hidden="true"></div>
        </div>
      );
    })}
  </div>

</section>