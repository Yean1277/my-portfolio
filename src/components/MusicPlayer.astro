---
import { playlist } from '../data/playlist';

const first = playlist[0];
const serialized = JSON.stringify(
  playlist.map(t => ({ ...t, src: `/music/${t.file}` }))
);
---

<style>
  .vinyl-record.playing {
    animation: vinyl-spin 3s linear infinite;
  }
  @keyframes vinyl-spin {
    to { transform: rotate(360deg); }
  }

  .playlist-drawer {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
  }
  .playlist-drawer.open {
    max-height: 320px;
    opacity: 1;
  }

  .playlist-inner {
    border-top: 1px solid #f1f5f9;
    padding-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow-y: auto;
    max-height: 210px;
  }
  .playlist-inner::-webkit-scrollbar { width: 5px; }
  .playlist-inner::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 99px; }
  .playlist-inner::-webkit-scrollbar-thumb { background: rgba(57,197,187,0.6); border-radius: 99px; }
  .playlist-inner::-webkit-scrollbar-thumb:hover { background: #39c5bb; }

  :global(.playlist-track) {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    gap: 10px;
    padding: 6px 8px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s;
    border: none;
    background: transparent;
    text-align: left;
    width: 100%;
    box-sizing: border-box;
  }
  :global(.playlist-track:hover) { background: rgba(57,197,187,0.07); }
  :global(.playlist-track.active) { background: rgba(57,197,187,0.12); }

  :global(.track-num) {
    font-size: 9px;
    font-family: monospace;
    color: #cbd5e1;
    width: 14px;
    text-align: right;
    flex-shrink: 0;
  }
  :global(.playlist-track.active .track-num) { color: #39c5bb; }

  :global(.playing-indicator) {
    display: none;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    align-items: flex-end;
    justify-content: center;
    gap: 1.5px;
  }
  :global(.playlist-track.active.is-playing .playing-indicator) { display: flex; }
  :global(.playlist-track.active.is-playing .track-num) { display: none; }

  :global(.playing-bar) {
    width: 2px;
    border-radius: 1px;
    background: #39c5bb;
    animation: eq 0.8s ease-in-out infinite alternate;
  }
  :global(.playing-bar:nth-child(1)) { height: 5px;  animation-delay: 0s; }
  :global(.playing-bar:nth-child(2)) { height: 9px;  animation-delay: 0.15s; }
  :global(.playing-bar:nth-child(3)) { height: 6px;  animation-delay: 0.3s; }
  @keyframes eq {
    from { transform: scaleY(0.4); }
    to   { transform: scaleY(1.2); }
  }

  :global(.pl-title) {
    font-size: 11px;
    font-weight: 600;
    color: #1e293b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.playlist-track.active .pl-title) { color: #39c5bb; }

  :global(.pl-artist) {
    font-size: 9px;
    color: #94a3b8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.pl-info) {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  :global(.pl-dur) {
    font-size: 9px;
    font-family: monospace;
    color: #cbd5e1;
    flex-shrink: 0;
  }
  :global(.playlist-track.active .pl-dur) { color: #39c5bb; }

  .list-btn.active {
    color: #39c5bb;
    background: rgba(57,197,187,0.1);
  }

</style>

<!-- Hidden audio engine -->
<audio id="audioEngine" preload="metadata"></audio>


<!-- Gradient border wrapper -->
<div class="relative" id="musicPlayerRoot" data-playlist={serialized}>
  <div class="absolute -inset-[2px] rounded-[26px] bg-gradient-to-br from-[#39c5bb]/30 to-orange-300/20 -z-10"></div>

  <div class="bg-white rounded-[24px] p-5 flex flex-col gap-3 shadow-[0_8px_30px_rgba(57,197,187,0.08)] hover:-translate-y-1 transition-transform">

    {playlist.length === 0 ? (
      <!-- Empty state -->
      <div class="flex items-center gap-3 py-1">
        <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center border-[3px] border-slate-200 shrink-0">
          <div class="w-3 h-3 bg-slate-300 rounded-full"></div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-[9px] font-black text-[#39c5bb] uppercase tracking-[0.2em] mb-0.5">Now Playing</p>
          <p class="text-[11px] text-slate-400 italic">No tracks — add MP3s to <code class="font-mono">src/data/playlist.ts</code></p>
        </div>
      </div>
    ) : (
      <!-- Player UI -->
      <div class="flex items-center gap-4">

        <!-- Vinyl disc -->
        <div
          class="w-12 h-12 rounded-full bg-slate-900 flex items-center justify-center border-[3px] border-[#39c5bb]/20 shrink-0 vinyl-record relative"
          id="vinyl"
          style="cursor: pointer;"
          title="Next track"
        >
          <div class="w-3 h-3 bg-[#39c5bb] rounded-full shadow-[0_0_8px_rgba(57,197,187,0.8)]"></div>
        </div>

        <!-- Track info -->
        <div class="flex-1 min-w-0">
          <p class="text-[9px] font-black text-[#39c5bb] uppercase tracking-[0.2em] mb-0.5">Now Playing</p>
          <h4 id="trackTitle" class="text-[13px] font-bold text-slate-900 truncate">{first?.title ?? ''}</h4>
          <p id="trackArtist" class="text-[10px] text-slate-400 truncate">{first?.artist ?? ''}</p>
        </div>

        <!-- Controls -->
        <div class="flex items-center gap-2 shrink-0">
          <button
            id="playBtn"
            class="w-10 h-10 flex items-center justify-center rounded-full border border-[#39c5bb]/30 text-slate-700 hover:border-[#39c5bb] hover:text-[#39c5bb] hover:bg-[#39c5bb]/10 transition-all outline-none"
            aria-label="Play / Pause"
          >
            <svg id="playIcon" class="h-4 w-4 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>

          <button
            id="listBtn"
            class="list-btn w-7 h-7 flex items-center justify-center rounded-full text-slate-400 hover:text-[#39c5bb] hover:bg-[#39c5bb]/10 transition-all outline-none"
            aria-label="Toggle playlist"
            title="Playlist"
          >
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/>
            </svg>
          </button>
        </div>
      </div>
    )}

    <!-- Playlist drawer (hidden when empty) -->
    {playlist.length > 0 && (
      <div class="playlist-drawer" id="playlistDrawer">
        <div class="playlist-inner" id="playlistInner"></div>
      </div>
    )}

  </div>
</div>

<script>
  const root    = document.getElementById('musicPlayerRoot');
  const tracks  = JSON.parse(root?.dataset.playlist ?? '[]') as Array<{
    id: number; title: string; artist: string; src: string; durationStr?: string;
  }>;

  if (tracks.length === 0) {
    // Nothing to wire up.
  } else {
    const audio          = document.getElementById('audioEngine') as HTMLAudioElement;
    const playBtn        = document.getElementById('playBtn')!;
    const playIcon       = document.getElementById('playIcon')!;
    const vinyl          = document.getElementById('vinyl')!;
    const titleEl        = document.getElementById('trackTitle')!;
    const artistEl       = document.getElementById('trackArtist')!;
    const listBtn        = document.getElementById('listBtn')!;
    const playlistDrawer = document.getElementById('playlistDrawer')!;
    const playlistInner  = document.getElementById('playlistInner')!;

    let currentIdx = 0;

    const PLAY_PATH  = '<path d="M8 5v14l11-7z"/>';
    const PAUSE_PATH = '<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>';

    /* ─── Playlist UI ── */
    function buildPlaylist() {
      tracks.forEach((track, idx) => {
        const btn = document.createElement('button');
        btn.className = 'playlist-track';
        btn.innerHTML = `
          <div class="track-num">${idx + 1}</div>
          <div class="playing-indicator">
            <div class="playing-bar"></div>
            <div class="playing-bar"></div>
            <div class="playing-bar"></div>
          </div>
          <div class="pl-info">
            <div class="pl-title">${track.title}</div>
            <div class="pl-artist">${track.artist}</div>
          </div>
          <span class="pl-dur">${track.durationStr ?? ''}</span>
        `;
        btn.addEventListener('click', () => goTo(idx, true));
        playlistInner.appendChild(btn);
      });
    }

    function syncPlaylistUI() {
      playlistInner.querySelectorAll('.playlist-track').forEach((el, idx) => {
        el.classList.toggle('active', idx === currentIdx);
        el.classList.toggle('is-playing', idx === currentIdx && !audio.paused);
      });
    }

    /* ─── Track switching ── */
    function goTo(idx: number, play = false) {
      currentIdx = idx;
      const track = tracks[idx];
      audio.src         = track.src;
      titleEl.textContent  = track.title;
      artistEl.textContent = track.artist;
      if (play) audio.play();
      syncPlaylistUI();
    }

    /* ─── Vinyl spin follows audio state ── */
    audio.addEventListener('play',  () => {
      vinyl.classList.add('playing');
      playIcon.innerHTML = PAUSE_PATH;
      playIcon.classList.remove('ml-0.5');
      syncPlaylistUI();
    });
    audio.addEventListener('pause', () => {
      vinyl.classList.remove('playing');
      playIcon.innerHTML = PLAY_PATH;
      playIcon.classList.add('ml-0.5');
      syncPlaylistUI();
    });

    /* ─── Auto-advance ── */
    audio.addEventListener('ended', () => {
      goTo((currentIdx + 1) % tracks.length, true);
    });

    /* ─── Controls ── */
    playBtn.addEventListener('click', () => {
      if (audio.src === '') goTo(currentIdx, true);
      else audio.paused ? audio.play() : audio.pause();
    });

    vinyl.addEventListener('click', () => {
      const wasPlaying = !audio.paused;
      vinyl.classList.remove('playing');
      setTimeout(() => goTo((currentIdx + 1) % tracks.length, wasPlaying), 50);
    });

    listBtn.addEventListener('click', () => {
      const isOpen = playlistDrawer.classList.toggle('open');
      listBtn.classList.toggle('active', isOpen);
    });

    /* ─── Init ── */
    buildPlaylist();
    goTo(0);

  }
</script>